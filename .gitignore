.DS_Store
.t3/
# Worktree-local PR body passed to `gh pr create --body-file`; never tracked.
.pr-body.md
__pycache__/
*.pyc
.venv/
.ruff_cache/
.pytest_cache/
.jscpd/
# mutmut scoped-run artifacts (generated by `t3 mutation run`; the setup.cfg /
# pytest.ini are auto-removed, the mutants/ tree is not).
mutants/
e2e/snapshot_tests_failures/
.coverage
*.egg-info/
dist/
!dist/sbom.json
build/
node_modules/
.claude/
docs/plan
# Per-ticket architecture pre-check scratch is ignored, but a tracked, permanent
# design/decision doc (ADR) under docs/design/ is carved back in explicitly.
docs/design/*
!docs/design/autonomous-lane-redesign.md
!docs/design/own-loop-scheduler.md
tach_module_graph.dot
htmlcov/
# mkdocs build output
site/
.mypy_cache/
.tox/
*.lock
*.min.js
*.min.css
*.map
# Vendored dashboard JS (htmx, mermaid) is load-bearing at runtime — the templates
# load it via {% static %}, so it MUST be tracked despite the *.min.js ignore above.
!src/teatree/dash/static/dash/js/*.min.js


# Local plugin marketplace self-reference (created by t3 setup)
plugins/

# pip-audit requirements export (transient, regenerated by CI + uv-audit hook)
requirements.audit.txt

# APM dependencies
apm_modules/
docs/plans/
.t3.local.json

# Transient XDG CLI state written into a worktree (e.g. `gh`'s device-id).
.local/

# E2E artifacts: server stdout/stderr capture + Playwright video recordings.
# Mounted writable into the e2e Docker container; useful when triaging CI failures.
e2e/.logs/
e2e/.videos/

# Per-ticket env cache (#390 stream B / #875): generated by `worktree start`,
# symlinked into each repo worktree root as `.t3-env.cache`. Source of truth is
# the DB; the file is regenerated on drift and must never be committed.
.t3-env.cache
.t3-cache/

# Autonomous review-loop runtime cursor (#924): written untracked at the
# clone root by the loop. Ignoring it keeps the clone clean so `t3 update`
# can always ff-advance the running editable t3 (it never blocked the
# fast-forward, but staying untracked-clean avoids any confusion).
.loop-review-state.json

# Worktree-local architecture pre-check scratch (the reviewer-facing summary
# lives in the PR body, not a tracked file — see skills/architecture-design).
ARCHITECTURE.md

# Box-side secrets file for the Hetzner headless deploy (tokens/admin creds).
# Written on the box by the deploy workflow; must never be committed.
deploy/teatree.env

# Captured eval transcripts (`t3 eval capture-subagent`, the `transcript`
# backend's input) are written as a plain `<scenario>.jsonl` to the cwd / the
# `--transcript-dir` (default the repo root). A REAL captured transcript holds
# personal session content and must NEVER reach this PUBLIC repo. The committed
# synthetic fixtures all live under `evals/fixtures/` with a `.stream.jsonl` /
# `.session.jsonl` infix, so ignoring the plain root-level `*.jsonl` capture
# target can never shadow a committed fixture. (#privacy: real transcripts stay
# uncommitted; the synthetic corpus_gen pipeline is the only committed source.)
/*.jsonl
.pr-body.md

# CI's cached migrated-sqlite test-DB template (test-shard job, perf(ci):
# skip redundant per-xdist-worker migrate). Never meant to be committed —
# only ever built by tests/conftest.py::django_db_setup into a runner-local
# or actions/cache-restored path.
/.cache/django-test-template/

# working notes for the mega consolidation - never commit
MEGA_NOTES.md

# one-shot analyses / plans - never committed (owner decision 2026-07-23)
docs/audits/
docs/research/
