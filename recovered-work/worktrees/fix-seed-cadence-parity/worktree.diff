diff --git tests/teatree_loops/test_seed.py tests/teatree_loops/test_seed.py
index c95578d79b..1475c82ee1 100644
--- tests/teatree_loops/test_seed.py
+++ tests/teatree_loops/test_seed.py
@@ -43,6 +43,34 @@ def test_seeded_loop_table_matches_iter_loops(self) -> None:
             f"seed/registry mismatch: seed-only={seeded - registry}, registry-only={registry - seeded}"
         )
 
+    def test_interval_seed_delay_matches_registry_cadence_for_every_loop(self) -> None:
+        # For every INTERVAL-cadence loop (a seed spec with no ``daily_at``), the
+        # registry ``MiniLoop.default_cadence_seconds`` is the source of truth and
+        # the seed's ``delay_seconds`` is the value installed into the ``Loop``
+        # row — ``Loop.is_due`` uses ``delay_seconds`` as the firing interval. The
+        # two MUST agree or a fresh install ticks the loop at a cadence that
+        # contradicts its own registry default (the pre-#2513 orchestration model
+        # left five seeds stale: audit/followup/arch_review/dogfood/eval_local).
+        #
+        # A ``daily_at``-scheduled seed (``news``, ``dream``) is excluded by
+        # design: ``Loop.is_due`` ignores ``delay_seconds`` entirely when
+        # ``daily_at`` is set (see ``Loop._daily_due``), so its ``delay_seconds``
+        # is a nominal placeholder, not the effective cadence — equating it to the
+        # registry interval would assert a constraint the model never enforces.
+        #
+        # This guard makes interval seed/registry cadence drift impossible to land
+        # silently again.
+        registry_cadence = {loop.name: loop.default_cadence_seconds for loop in iter_loops()}
+        interval_seed_delay = {spec.name: spec.delay_seconds for spec in DEFAULT_LOOPS if spec.daily_at is None}
+        missing = interval_seed_delay.keys() - registry_cadence.keys()
+        assert not missing, f"interval seed loops absent from the registry: {missing}"
+        drift = {
+            name: (delay, registry_cadence[name])
+            for name, delay in interval_seed_delay.items()
+            if delay != registry_cadence[name]
+        }
+        assert not drift, f"seed delay_seconds != registry default_cadence_seconds for {drift}"
+
     def test_seed_is_idempotent_no_duplicate_rows(self) -> None:
         seed_default_loops_and_prompts()
         first = Loop.objects.count()
