 src/teatree/core/public_identity.py           | 59 +++++++++++++++--
 src/teatree/core/runners/provision.py         |  8 ++-
 tests/teatree_core/test_public_identity.py    | 57 ++++++++++++++++
 tests/teatree_core/test_runners_provision.py  | 65 +++++++++++++++++--
 5 files changed, 187 insertions(+), 14 deletions(-)

