+class SpecCoverageItem(TypedDict, total=False):
+    """One acceptance-criterion -> backing-test mapping (#2232).
+
+    An item of the ticket's ``extra['spec_coverage']`` manifest. ``ac`` is the
+    human-readable acceptance criterion; ``test`` is the reference to the test
+    that backs it (a ``path::node-id``, an eval scenario, a golden-master file).
+    The spec-coverage done-gate (``teatree.core.gates.spec_coverage_gate``)
+    treats an item with a blank ``test`` as an uncovered AC and refuses
+    DELIVERED when the gate is required.
+    """
+
+    ac: str
+    test: str
+
+
+class SpecCoverageOverride(TypedDict, total=False):
+    """Operator escape hatch for the spec-coverage done-gate (#2232).
+
+    Records the human-supplied justification for delivering a feature ticket
+    whose acceptance criteria are not all test-backed via the manifest (a
+    genuinely exempt ticket, or one whose spec is tracked outside teatree),
+    plus who recorded it and when, so the bypass is auditable rather than
+    silent.
+    """
+
+    reason: str
+    by: str
+    at: str
+
+
