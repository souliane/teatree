+# Pre-rename setting keys that map UP to their current canonical name on read, so
+# a value persisted under the old name (a stored ``ConfigSetting`` row, a
+# ``[teatree]`` / ``[overlays.<name>]`` TOML key being migrated) is never silently
+# dropped after a rename. The canonical form is always the NEW (value) name — the
+# alias is read-only and one-directional (old -> new), per the "normalize UP to the
+# fully-qualified/canonical key" principle (architecture-design § 8). #129's
+# task-sweep scanner renamed ``todo_sweep_*`` -> ``task_sweep_*`` (the keys named
+# teatree ``Task`` rows, never the harness TODO list — the forbidden conflation).
+LEGACY_SETTING_KEY_ALIASES: dict[str, str] = {
+    "todo_sweep_disabled": "task_sweep_disabled",
+    "todo_sweep_recheck_interval_hours": "task_sweep_recheck_interval_hours",
+}
+
+
+def canonical_setting_key(key: str) -> str:
+    """Resolve a setting key to its canonical name, mapping any legacy alias UP.
+
+    A key registered under its current name returns unchanged; a pre-rename
+    alias in :data:`LEGACY_SETTING_KEY_ALIASES` resolves to the current
+    canonical name. The single home for the read-time key migration, applied at
+    every boundary that reads a persisted key (the DB-row resolver and the
+    TOML -> DB import), so an old-named value resolves into the new field
+    instead of being dropped as unknown.
+    """
+    return LEGACY_SETTING_KEY_ALIASES.get(key, key)
+
