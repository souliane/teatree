+class TestRegisteredInChain:
+    def test_handler_is_in_pretooluse_chain(self) -> None:
+        assert handle_enforce_orchestrator_investigation_boundary in router._HANDLERS["PreToolUse"]
+
+    def test_handler_never_reaches_deny_emitter(self) -> None:
+        # A structural pin: the nudge must never call emit_pretooluse_deny, so it
+        # can never appear as a lockout-prone deny gate. (The never-lockout
+        # contract test only inspects deny gates; this proves this handler isn't
+        # one.)
+        import ast  # noqa: PLC0415
+
+        tree = ast.parse(Path(router.__file__).read_text(encoding="utf-8"))
+        target = next(
+            n
+            for n in ast.walk(tree)
+            if isinstance(n, ast.FunctionDef) and n.name == "handle_enforce_orchestrator_investigation_boundary"
+        )
+        called = {
+            node.func.id for node in ast.walk(target) if isinstance(node, ast.Call) and isinstance(node.func, ast.Name)
+        }
+        assert "emit_pretooluse_deny" not in called
