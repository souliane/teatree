+@redis_app.command(name="upgrade")
+def redis_upgrade() -> None:
+    """Recreate the shared Redis container to apply a raised ``redis_db_count``.
+
+    This is the **destructive** resize path: it stops + removes + recreates the
+    container with the configured pool, dropping the cache + Celery broker state
+    of every worktree. Refuses while a worktree is live (``services_up``/``ready``)
+    so shared state is never nuked out from under a running stack — tear those
+    down first (``t3 <overlay> worktree teardown <path>``) and re-run.
+    """
+    from teatree.core.models import Worktree  # noqa: PLC0415
+
+    blockers = list(Worktree.objects.live_stacks())
+    if blockers:
+        names = ", ".join(f"{w.repo_path} ({w.branch})" for w in blockers)
+        typer.echo(
+            "Refusing to recreate teatree-redis: live worktree(s) would lose "
+            f"cache/broker state: {names}. Tear them down and re-run.",
+            err=True,
+        )
+        raise typer.Exit(code=1)
+    redis_container.ensure_running(
+        db_count=load_config().user.redis_db_count,
+        allow_resize_recreate=True,
+    )
     typer.echo(f"{redis_container.CONTAINER_NAME}: {redis_container.status()}")
 
 
