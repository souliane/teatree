@@ -0,0 +1,212 @@
+# test-path: cross-cutting — tests hook_router.py (hooks/) + teatree.core.gates.config_overwrite_guard.
+"""Tests for the config-overwrite data-loss gate.
+
+A working-tree-destroying git op (``git checkout -- <path>`` / ``git restore``
+/ ``git reset --hard`` / ``git stash``) — or a full-file ``Write`` — that would
+clobber a TRACKED config/dotfile carrying UNCOMMITTED changes is denied. The
+classic data-loss move: "found a version in git and restored it" over a live
+dotfile whose working-tree edits were newer than ``HEAD``.
+
+Anti-vacuity: the core fixture is a real ``git init`` repo with a COMMITTED
+tracked ``.claude/settings.json`` and an uncommitted edit on top. The gate
+BLOCKS ``git checkout -- .claude/settings.json`` (red without the gate). The
+companion allow-tests prove the block is SCOPED: a clean config file, a source
+file, an untracked file, a surgical ``Edit``, and the never-lockout escapes all
+proceed.
+"""
+
+import json
+import os
+import subprocess
+from pathlib import Path
+
+import pytest
+
+import hooks.scripts.config_overwrite_guard as gate
+import hooks.scripts.hook_router as router
+from teatree.core.gates import config_overwrite_guard as core
+
+
+def _git(cwd: Path, *args: str) -> None:
+    subprocess.run(
+        ["git", *args],  # noqa: S607
+        cwd=cwd,
+        check=True,
+        capture_output=True,
+        env={
+            **os.environ,
+            "GIT_CONFIG_GLOBAL": "/dev/null",
+            "GIT_CONFIG_SYSTEM": "/dev/null",
+            "GIT_AUTHOR_NAME": "t",
+            "GIT_AUTHOR_EMAIL": "t@t",
+            "GIT_COMMITTER_NAME": "t",
+            "GIT_COMMITTER_EMAIL": "t@t",
+        },
+    )
+
+
+def _repo_with_committed_config(tmp_path: Path) -> Path:
+    """A git repo with a COMMITTED tracked ``.claude/settings.json``."""
+    repo = tmp_path / "dotfiles"
+    repo.mkdir()
+    _git(repo, "init", "-b", "main")
+    cfg = repo / ".claude" / "settings.json"
+    cfg.parent.mkdir()
+    cfg.write_text('{"committed": true}\n')
+    _git(repo, "add", "-A")
+    _git(repo, "commit", "-m", "initial config")
+    return repo
+
+
+def _bash_event(command: str, cwd: Path) -> dict:
+    return {"session_id": "sess-cfg", "tool_name": "Bash", "tool_input": {"command": command}, "cwd": str(cwd)}
+
+
+def _write_event(file_path: str, cwd: Path, content: str = "{}") -> dict:
+    return {
+        "session_id": "sess-cfg",
+        "tool_name": "Write",
+        "tool_input": {"file_path": file_path, "content": content},
+        "cwd": str(cwd),
+    }
+
+
+def _parse_deny(capsys: pytest.CaptureFixture[str]) -> dict | None:
+    out = capsys.readouterr().out.strip()
+    return json.loads(out) if out else None
+
+
+@pytest.fixture(autouse=True)
+def _gate_on(monkeypatch: pytest.MonkeyPatch) -> None:
+    """Force the gate ENABLED and bootstrap a no-op so the env's config never disables it."""
+    monkeypatch.setattr(gate, "_gate_enabled", lambda: True)
+    monkeypatch.setattr(gate, "_bootstrap", lambda: True)
+
+
+class TestBlocksDirtyConfigRestore:
+    """The data-loss path: a destructive op over a dirty tracked config/dotfile."""
+
+    def test_git_checkout_over_dirty_config_is_blocked(
+        self, tmp_path: Path, capsys: pytest.CaptureFixture[str]
+    ) -> None:
+        repo = _repo_with_committed_config(tmp_path)
+        # Uncommitted working-tree edit — the experimental config the restore would destroy.
+        (repo / ".claude" / "settings.json").write_text('{"experimental": "agent-team"}\n')
+
+        verdict = router.handle_block_config_overwrite(_bash_event("git checkout -- .claude/settings.json", repo))
+
+        assert verdict is True
+        deny = _parse_deny(capsys)
+        assert deny is not None
+        assert deny["permissionDecision"] == "deny"
+        assert ".claude/settings.json" in deny["permissionDecisionReason"]
+        assert "UNCOMMITTED" in deny["permissionDecisionReason"]
+
+    def test_git_restore_over_dirty_config_is_blocked(self, tmp_path: Path, capsys: pytest.CaptureFixture[str]) -> None:
+        repo = _repo_with_committed_config(tmp_path)
+        (repo / ".claude" / "settings.json").write_text('{"edited": true}\n')
+        assert router.handle_block_config_overwrite(_bash_event("git restore .claude/settings.json", repo)) is True
+        assert _parse_deny(capsys)["permissionDecision"] == "deny"  # type: ignore[index]
+
+    def test_git_reset_hard_with_dirty_config_is_blocked(
+        self, tmp_path: Path, capsys: pytest.CaptureFixture[str]
+    ) -> None:
+        repo = _repo_with_committed_config(tmp_path)
+        (repo / ".claude" / "settings.json").write_text('{"edited": true}\n')
+        # reset --hard names no path but sweeps the whole tree → the dirty config is at risk.
+        assert router.handle_block_config_overwrite(_bash_event("git reset --hard HEAD", repo)) is True
+        assert _parse_deny(capsys)["permissionDecision"] == "deny"  # type: ignore[index]
+
+    def test_git_stash_with_dirty_config_is_blocked(self, tmp_path: Path, capsys: pytest.CaptureFixture[str]) -> None:
+        repo = _repo_with_committed_config(tmp_path)
+        (repo / ".claude" / "settings.json").write_text('{"edited": true}\n')
+        assert router.handle_block_config_overwrite(_bash_event("git stash", repo)) is True
+        assert _parse_deny(capsys)["permissionDecision"] == "deny"  # type: ignore[index]
+
+    def test_full_file_write_over_dirty_config_is_blocked(
+        self, tmp_path: Path, capsys: pytest.CaptureFixture[str]
+    ) -> None:
+        repo = _repo_with_committed_config(tmp_path)
+        (repo / ".claude" / "settings.json").write_text('{"edited": true}\n')
+        event = _write_event(str(repo / ".claude" / "settings.json"), repo, content='{"from": "git"}')
+        assert router.handle_block_config_overwrite(event) is True
+        assert _parse_deny(capsys)["permissionDecision"] == "deny"  # type: ignore[index]
+
+
+class TestAllowsSafeAndOutOfScope:
+    """The block is SCOPED — these proceed (verdict False, no deny written)."""
+
+    def test_clean_config_restore_is_allowed(self, tmp_path: Path, capsys: pytest.CaptureFixture[str]) -> None:
+        repo = _repo_with_committed_config(tmp_path)  # no uncommitted edit → nothing to lose
+        assert router.handle_block_config_overwrite(_bash_event("git checkout -- .claude/settings.json", repo)) is False
+        assert _parse_deny(capsys) is None
+
+    def test_source_file_restore_is_allowed(self, tmp_path: Path, capsys: pytest.CaptureFixture[str]) -> None:
+        repo = _repo_with_committed_config(tmp_path)
+        src = repo / "models.py"
+        src.write_text("x = 1\n")
+        _git(repo, "add", "-A")
+        _git(repo, "commit", "-m", "src")
+        src.write_text("x = 2\n")  # dirty, but a SOURCE file — out of scope
+        assert router.handle_block_config_overwrite(_bash_event("git checkout -- models.py", repo)) is False
+        assert _parse_deny(capsys) is None
+
+    def test_untracked_config_write_is_allowed(self, tmp_path: Path, capsys: pytest.CaptureFixture[str]) -> None:
+        repo = _repo_with_committed_config(tmp_path)
+        new_cfg = repo / ".claude" / "new.json"  # not tracked → no committed version to clobber
+        new_cfg.write_text("{}\n")
+        assert router.handle_block_config_overwrite(_write_event(str(new_cfg), repo)) is False
+        assert _parse_deny(capsys) is None
+
+    def test_branch_switch_without_path_is_allowed(self, tmp_path: Path, capsys: pytest.CaptureFixture[str]) -> None:
+        repo = _repo_with_committed_config(tmp_path)
+        (repo / ".claude" / "settings.json").write_text('{"edited": true}\n')
+        # ``git checkout main`` names a branch, not a path — out of scope.
+        assert router.handle_block_config_overwrite(_bash_event("git checkout main", repo)) is False
+        assert _parse_deny(capsys) is None
+
+    def test_non_destructive_git_command_is_allowed(self, tmp_path: Path, capsys: pytest.CaptureFixture[str]) -> None:
+        repo = _repo_with_committed_config(tmp_path)
+        (repo / ".claude" / "settings.json").write_text('{"edited": true}\n')
+        assert router.handle_block_config_overwrite(_bash_event("git status", repo)) is False
+        assert _parse_deny(capsys) is None
+
+
+class TestNeverLockout:
+    """Escapes: per-call token, kill-switch, unresolvable cwd."""
+
+    def test_per_call_token_allows(self, tmp_path: Path, capsys: pytest.CaptureFixture[str]) -> None:
+        repo = _repo_with_committed_config(tmp_path)
+        (repo / ".claude" / "settings.json").write_text('{"edited": true}\n')
+        cmd = "git checkout -- .claude/settings.json  # [config-overwrite-ok: intentional revert]"
+        assert router.handle_block_config_overwrite(_bash_event(cmd, repo)) is False
+        assert _parse_deny(capsys) is None
+
+    def test_kill_switch_disables(
+        self, tmp_path: Path, capsys: pytest.CaptureFixture[str], monkeypatch: pytest.MonkeyPatch
+    ) -> None:
+        monkeypatch.setattr(gate, "_gate_enabled", lambda: False)
+        repo = _repo_with_committed_config(tmp_path)
+        (repo / ".claude" / "settings.json").write_text('{"edited": true}\n')
+        assert router.handle_block_config_overwrite(_bash_event("git checkout -- .claude/settings.json", repo)) is False
+        assert _parse_deny(capsys) is None
+
+    def test_unresolvable_cwd_allows(self, tmp_path: Path, capsys: pytest.CaptureFixture[str]) -> None:
+        event = {"session_id": "s", "tool_name": "Bash", "tool_input": {"command": "git reset --hard"}, "cwd": ""}
+        assert router.handle_block_config_overwrite(event) is False
+        assert _parse_deny(capsys) is None
+
+
+class TestCoreScopeClassifier:
+    """Pure-logic unit coverage for the config/dotfile scope classifier."""
+
+    @pytest.mark.parametrize(
+        "path",
+        [".claude/settings.json", ".teatree.toml", "CLAUDE.md", ".zshrc", "home/.config/foo/bar.conf", ".gitconfig"],
+    )
+    def test_in_scope(self, path: str) -> None:
+        assert core.is_config_path(path) is True
+
+    @pytest.mark.parametrize("path", ["src/models.py", "app/views.ts", "README.md", "lib/util.go", ""])
+    def test_out_of_scope(self, path: str) -> None:
+        assert core.is_config_path(path) is False
