index 0000000000..4b8365df19
--- /dev/null
+++ hooks/scripts/config_overwrite_guard.py
@@ -0,0 +1,203 @@
+"""PreToolUse: block a destructive overwrite/restore of a dirty tracked config.
+
+Guards a tracked config/dotfile carrying UNCOMMITTED working-tree changes
+against a data-loss overwrite/restore. Two surfaces, one rule (``/t3:rules``
+§ "Read Before Overwriting a Tracked Config/Dotfile"):
+
+1.  **Bash** — a working-tree-destroying git op (``git checkout -- <path>`` /
+    ``git restore <path>`` / ``git reset --hard`` / ``git stash``) that would
+    clobber a tracked config/dotfile with uncommitted changes. Detection +
+    git-state logic lives in the pure core module
+    :mod:`teatree.core.gates.config_overwrite_guard`.
+2.  **Write** — a full-file ``Write`` over a tracked config/dotfile that has
+    uncommitted changes (whole-file replacement, the form that caused the
+    real data loss). A surgical ``Edit`` is NOT in scope — only a wholesale
+    ``Write`` that discards the current content.
+
+Scope is deliberately narrow (``.claude/*``, ``.teatree.toml``, dotfiles, known
+config basenames) so normal source-file git ops and source-file writes are
+never blocked.
+
+Never-lockout: a per-call ``[config-overwrite-ok: <reason>]`` token ALLOWS that
+one call; the ``[teatree] config_overwrite_gate_enabled = false`` kill-switch
+disables it globally (default on, fails OPEN); the deny routes through
+``_fail_open_or_deny`` so the self-rescue allowlist + master fail-open switch +
+circuit breaker all apply. An unresolvable cwd, an untracked file, a clean
+config file, or any internal exception all fail OPEN.
+
+The helpers that resolve the cwd and emit the deny (``_resolve_cwd_repo``,
+``_fail_open_or_deny``, ``_teatree_bool_setting``) live in ``hook_router`` and
+are imported lazily at call time — ``hook_router`` imports this module at top
+level, so importing it back at top level here would be a cycle.
+"""
+
+import re
+import sys
+from pathlib import Path
+
+# Alias the bare and ``hooks.scripts.`` identities so the handler the router
+# registers and a test patching a helper here operate on ONE module object
+# (mirrors unknown_repo_push_gate).
+sys.modules.setdefault("config_overwrite_guard", sys.modules[__name__])
+sys.modules.setdefault("hooks.scripts.config_overwrite_guard", sys.modules[__name__])
+
+_OVERWRITE_OK_RE = re.compile(r"\[config-overwrite-ok:\s*(\S[^\]]*?)\s*\]")
+# The tools this gate evaluates: a Bash git op or a full-file Write. A surgical
+# Edit is deliberately NOT in scope — only a wholesale Write discards content.
+_IN_SCOPE_TOOLS = frozenset({"Bash", "Write"})
+
+
+def _gate_enabled() -> bool:
+    """Whether the config-overwrite gate is enabled (default True).
+
+    Fails OPEN to enabled on a missing/broken config; an explicit bare
+    ``[teatree] config_overwrite_gate_enabled = false`` is the one-line
+    kill-switch (never a code edit).
+    """
+    from hook_router import _teatree_bool_setting  # noqa: PLC0415, PLC2701
+
+    return _teatree_bool_setting("config_overwrite_gate_enabled", default=True)
+
+
+def _overwrite_ok_token(text: str) -> str | None:
+    """Return the reason from a ``[config-overwrite-ok: <reason>]`` token, else None.
+
+    Scanned within the first 512 chars (mirroring the other per-call escapes);
+    an empty reason returns None so a bare token cannot disarm the gate.
+    """
+    match = _OVERWRITE_OK_RE.search(text[:512])
+    if not match:
+        return None
+    reason = match.group(1).strip()
+    return reason or None
+
+
+def _bootstrap() -> bool:
+    """Bootstrap Django so the core gate's imports resolve in the hook subprocess.
+
+    The core module imports only ``teatree.utils.run`` (no ORM), but importing
+    through the ``teatree`` package still benefits from the shared bootstrap's
+    ``sys.path`` setup. Fails OPEN (returns False → caller allows) on any error.
+    """
+    try:
+        from django_bootstrap import bootstrap_teatree_django  # noqa: PLC0415
+
+        return bool(bootstrap_teatree_django())
+    except Exception:  # noqa: BLE001 — a broken bootstrap must never wedge a tool call.
+        return False
+
+
+def _write_overwrites_dirty_config(repo: Path, file_path: str) -> bool:
+    """Whether a full-file ``Write`` to *file_path* clobbers a dirty tracked config.
+
+    True only when *file_path* is a config/dotfile AND is tracked in *repo* AND
+    has uncommitted working-tree changes. Any internal error fails OPEN.
+    """
+    try:
+        from teatree.core.gates import config_overwrite_guard as core  # noqa: PLC0415
+
+        if not core.is_config_path(file_path):
+            return False
+        toplevel = core._toplevel(repo)  # noqa: SLF001 — intra-gate helper reuse.
+        if toplevel is None:
+            return False
+        return core.is_tracked(toplevel, file_path) and core.has_uncommitted_changes(toplevel, file_path)
+    except Exception:  # noqa: BLE001 — fail OPEN; a resolver bug must not brick a Write.
+        return False
+
+
+def _evaluate_bash(repo: Path, command: str) -> str | None:
+    """Return the block reason if *command* would clobber a dirty config, else None.
+
+    Delegates to the pure core evaluator. Any internal error fails OPEN.
+    """
+    try:
+        from teatree.core.gates import config_overwrite_guard as core  # noqa: PLC0415
+
+        verdict = core.evaluate(command, repo)
+    except Exception:  # noqa: BLE001 — fail OPEN; a resolver bug must not brick a git op.
+        return None
+    return verdict.reason if verdict.blocked else None
+
+
+def _write_block_reason(file_path: str) -> str:
+    return (
+        f"BLOCKED: this `Write` replaces the WHOLE content of a tracked config/dotfile "
+        f"(`{file_path}`) that has UNCOMMITTED working-tree changes. A live dotfile's uncommitted "
+        f"edits are almost always newer than the committed version — overwriting the whole file "
+        f"drops them with no recovery. Read the current content first, then make a SURGICAL `Edit` "
+        f"of only the lines you mean to change. If a full overwrite is genuinely intended, snapshot "
+        f"the file aside first and append `[config-overwrite-ok: <reason>]` to the content."
+    )
+
+
+def _bash_block_reason(cwd: Path, tool_input: dict) -> str | None:
+    """Block reason for a ``Bash`` git op, or ``None`` to allow.
+
+    Allows on an empty command, a present per-call token, a failed bootstrap,
+    or a non-destructive / out-of-scope command.
+    """
+    command = tool_input.get("command", "")
+    if not command:
+        return None
+    if reason_token := _overwrite_ok_token(command):
+        sys.stderr.write(f"NOTE: config-overwrite gate skipped via [config-overwrite-ok: {reason_token}].\n")
+        return None
+    if not _bootstrap():
+        return None
+    return _evaluate_bash(cwd, command)
+
+
+def _write_block_reason_or_none(cwd: Path, tool_input: dict) -> str | None:
+    """Block reason for a full-file ``Write`` over a dirty tracked config, or ``None``.
+
+    Allows on a missing path, a present per-call token, a failed bootstrap, or
+    a file that is not a dirty tracked config/dotfile.
+    """
+    file_path = tool_input.get("file_path", "")
+    if not file_path:
+        return None
+    if _overwrite_ok_token(tool_input.get("content", "")) or _overwrite_ok_token(file_path):
+        sys.stderr.write("NOTE: config-overwrite gate skipped via [config-overwrite-ok: ...].\n")
+        return None
+    if not _bootstrap():
+        return None
+    if not _write_overwrites_dirty_config(cwd, file_path):
+        return None
+    return _write_block_reason(file_path)
+
+
+def handle_block_config_overwrite(data: dict) -> bool:
+    """Block a destructive overwrite/restore of a dirty tracked config/dotfile.
+
+    Fires for:
+
+    *   ``Bash`` running a working-tree-destroying git op (``git checkout`` /
+        ``restore`` with a config path, ``git reset --hard``, ``git stash``)
+        that would clobber a tracked config/dotfile with uncommitted changes;
+    *   ``Write`` replacing the whole content of such a file.
+
+    Every other case ALLOWS: a non-destructive command, an op on a source
+    file, a clean or untracked config file, a surgical ``Edit``, the gate
+    disabled, a present ``[config-overwrite-ok: <reason>]`` token, an
+    unresolvable cwd, or any internal error. The deny routes through
+    :func:`_fail_open_or_deny` (self-rescue allowlist + master fail-open +
+    circuit breaker — never-lockout).
+    """
+    from hook_router import _fail_open_or_deny, _resolve_cwd_repo  # noqa: PLC0415, PLC2701
+
+    tool_name = data.get("tool_name", "")
+    if tool_name not in _IN_SCOPE_TOOLS or not _gate_enabled():
+        return False
+    cwd = _resolve_cwd_repo(data)
+    if cwd is None:
+        return False
+
+    tool_input = data.get("tool_input", {})
+    if tool_name == "Bash":
+        reason = _bash_block_reason(cwd, tool_input)
+    else:
+        reason = _write_block_reason_or_none(cwd, tool_input)
+    if reason is None:
+        return False
+    return _fail_open_or_deny(data, reason)
