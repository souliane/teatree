new file mode 100644
index 0000000000..621b128701
--- /dev/null
+++ src/teatree/core/gates/config_overwrite_guard.py
@@ -0,0 +1,314 @@
+"""Block a destructive overwrite/restore of a dirty tracked config/dotfile.
+
+Targets a tracked config/dotfile carrying UNCOMMITTED working-tree changes.
+
+A live config/dotfile under git (``.claude/settings.json``, ``.teatree.toml``,
+a shell rc, any dotfile) almost always carries working-tree edits that are
+MORE current than ``HEAD`` — that is the normal state of a dotfiles repo. An
+operation that replaces the file's whole content with the committed version —
+``git checkout -- <path>`` / ``git restore <path>`` / ``git reset --hard`` /
+``git stash`` (which shelves the working tree), or a full-file ``Write`` over
+the tracked dotfile — silently discards exactly those edits with no recovery
+path unless they were staged. "Found a version in git and restored it" is the
+classic data-loss move.
+
+This gate is the deterministic enforcement of ``/t3:rules`` § "Read Before
+Overwriting a Tracked Config/Dotfile". It refuses such an operation when the
+target is a tracked config/dotfile with uncommitted changes, unless the
+operation is explicitly confirmed (a per-call token the hook layer honours).
+
+**Scope is deliberately narrow.** It fires ONLY for config/dotfiles — paths
+matching :data:`_CONFIG_PATH_PATTERNS` (``.claude/*``, ``.teatree*``, a
+dotfile, or a known config basename). A normal source file (``models.py``,
+``views.ts``) is never in scope, so everyday ``git checkout -- src/foo.py`` to
+discard an unwanted edit is untouched. The pure logic lives here in
+``teatree.core``; the thin ``PreToolUse`` adapter is the sibling hook module
+``hooks/scripts/config_overwrite_guard.py``.
+"""
+
+import re
+from dataclasses import dataclass, field
+from pathlib import Path, PurePosixPath
+
+from teatree.utils.run import run_allowed_to_fail
+
+# --------------------------------------------------------------------------- #
+# Config / dotfile scope
+# --------------------------------------------------------------------------- #
+
+# A path is in scope when ANY of its segments / its basename matches one of
+# these. The intent is "agent/user configuration and dotfiles", NOT source.
+_CONFIG_DIR_SEGMENTS: frozenset[str] = frozenset({".claude", ".config", ".teatree"})
+_CONFIG_BASENAMES: frozenset[str] = frozenset(
+    {
+        ".teatree.toml",
+        "settings.json",
+        "settings.local.json",
+        ".cursorrules",
+        ".env",
+        "claude.md",  # matched case-insensitively below
+        "agents.md",
+        ".gitconfig",
+        ".zshrc",
+        ".bashrc",
+        ".bash_profile",
+        ".profile",
+        ".tmux.conf",
+        ".vimrc",
+    },
+)
+# A bare dotfile basename (``.foorc``, ``.teatree.toml``, ``.zshrc``) is in
+# scope; a ``.py`` / ``.ts`` / ``.md`` source file is not (those are matched by
+# extension below and explicitly excluded).
+_SOURCE_SUFFIXES: frozenset[str] = frozenset(
+    {".py", ".ts", ".tsx", ".js", ".jsx", ".html", ".css", ".scss", ".java", ".go", ".rs", ".c", ".cpp", ".h"},
+)
+
+
+def is_config_path(path: str) -> bool:
+    """Whether *path* names a config/dotfile this gate protects.
+
+    In scope: anything under a ``.claude`` / ``.config`` / ``.teatree``
+    directory, a known config basename (``settings.json``, ``.teatree.toml``,
+    ``CLAUDE.md``, …), or a leading-dot dotfile that is not a recognised
+    source file. Out of scope: ordinary source files, so normal source-file
+    git operations are never blocked.
+    """
+    if not path:
+        return False
+    posix = PurePosixPath(path.strip())
+    parts = posix.parts
+    name = posix.name
+    lower_name = name.lower()
+
+    if any(segment in _CONFIG_DIR_SEGMENTS for segment in parts):
+        return True
+    if lower_name in _CONFIG_BASENAMES:
+        return True
+    # A leading-dot dotfile (``.zshrc``, ``.teatree.toml``, ``.foorc``) that is
+    # not a source file by extension. ``.gitignore``-style dotfiles count.
+    return name.startswith(".") and posix.suffix.lower() not in _SOURCE_SUFFIXES
+
+
+# --------------------------------------------------------------------------- #
+# git working-tree state
+# --------------------------------------------------------------------------- #
+
+
+def _git(repo: Path, *args: str) -> tuple[int, str]:
+    """Return ``(returncode, stdout)`` for ``git -C <repo> <args>``.
+
+    Uses :func:`run_allowed_to_fail` so a non-zero exit (not a repo, bad ref)
+    yields a probe-style result the caller interprets, never a crash.
+    """
+    result = run_allowed_to_fail(["git", "-C", str(repo), *args], expected_codes=None)
+    return result.returncode, result.stdout.strip()
+
+
+def _toplevel(repo: Path) -> Path | None:
+    rc, out = _git(repo, "rev-parse", "--show-toplevel")
+    if rc != 0 or not out:
+        return None
+    return Path(out)
+
+
+def is_tracked(repo: Path, path: str) -> bool:
+    """Whether *path* is a file git tracks in *repo*.
+
+    An UNtracked file (a brand-new dotfile, or one in ``.gitignore``) carries
+    no committed version to be clobbered by a restore, so it is out of scope.
+    """
+    rc, _ = _git(repo, "ls-files", "--error-unmatch", "--", path)
+    return rc == 0
+
+
+def has_uncommitted_changes(repo: Path, path: str) -> bool:
+    """Whether the tracked *path* differs from ``HEAD`` in the working tree or index.
+
+    ``git status --porcelain -- <path>`` emits a line for any unstaged OR
+    staged modification; an empty result means the working tree matches
+    ``HEAD`` (nothing would be lost by a restore). This is the load-bearing
+    safety predicate: a restore only destroys data when uncommitted edits
+    exist.
+    """
+    rc, out = _git(repo, "status", "--porcelain", "--", path)
+    if rc != 0:
+        # Can't determine state — fail closed at the predicate level so the
+        # caller treats the file as dirty (safer to over-warn on a config file
+        # than to silently allow a clobber). The hook adapter still owns the
+        # never-lockout escapes.
+        return True
+    return bool(out.strip())
+
+
+# --------------------------------------------------------------------------- #
+# Destructive-command detection
+# --------------------------------------------------------------------------- #
+
+# ``git checkout -- <path>`` / ``git checkout <path>`` / ``git restore <path>``
+# all overwrite the working-tree file with the committed (or staged) content.
+_GIT_CHECKOUT_RE = re.compile(r"\bgit\s+checkout\b")
+_GIT_RESTORE_RE = re.compile(r"\bgit\s+restore\b")
+# ``git reset --hard`` discards ALL working-tree changes (path-scoped or not).
+_GIT_RESET_HARD_RE = re.compile(r"\bgit\s+reset\b[^\n;|&]*?--hard\b")
+# ``git stash`` (push, the default) shelves the working tree away — a config
+# file's edits vanish from the tree, and a later ``stash drop`` loses them.
+_GIT_STASH_RE = re.compile(r"\bgit\s+stash\b(?!\s+(?:list|show|branch))")
+# Switching branches with a path is not destructive; ``git checkout <branch>``
+# without a path is out of scope (handled by path extraction below).
+
+
+@dataclass(frozen=True, slots=True)
+class DestructiveOp:
+    """A parsed destructive working-tree git op and the paths it names."""
+
+    verb: str  # "checkout" | "restore" | "reset --hard" | "stash"
+    paths: tuple[str, ...]  # explicit path arguments (may be empty for reset --hard / stash)
+    sweeps_whole_tree: bool  # True for ``reset --hard`` / ``stash`` (no path needed to hit a config file)
+
+
+def _split_args(command: str) -> list[str]:
+    """Tokenise *command* loosely on whitespace, stripping surrounding quotes.
+
+    Good enough for pulling path-shaped positionals out of a ``git`` invocation
+    in a PreToolUse hook; the gate does not need a full shell parser, and a
+    quoted span it cannot resolve simply yields fewer path tokens (the
+    whole-tree verbs do not depend on path extraction at all).
+    """
+    return [tok.strip("'\"") for tok in command.split()]
+
+
+def _extract_path_args(command: str) -> tuple[str, ...]:
+    """Return the path-shaped positionals after the ``git <verb>``.
+
+    Everything after a literal ``--`` is a path. Without an explicit ``--``,
+    a trailing non-flag token that is not a bare branch ref heuristically
+    counts (``git checkout -- f`` is unambiguous; ``git checkout f`` is
+    treated as a path too, since this gate only matters once that token names
+    a config file). Flags and their inline values are skipped.
+    """
+    tokens = _split_args(command)
+    try:
+        start = tokens.index("git") + 2  # skip "git" and the verb
+    except ValueError:
+        start = 0
+    rest = tokens[start:]
+    if "--" in rest:
+        return tuple(p for p in rest[rest.index("--") + 1 :] if p)
+    # No explicit ``--``: take trailing non-flag tokens as candidate paths.
+    return tuple(tok for tok in rest if tok and not tok.startswith("-"))
+
+
+def parse_destructive_op(command: str) -> DestructiveOp | None:
+    """Parse a Bash *command* into a :class:`DestructiveOp`, or ``None``.
+
+    Recognises the four working-tree-destroying git forms named in the rule:
+    ``git checkout`` (with a path), ``git restore`` (with a path),
+    ``git reset --hard``, and ``git stash`` (push). ``reset --hard`` and
+    ``stash`` sweep the whole tree, so they need no path argument to endanger a
+    config file. A read-only ``git stash list/show`` is excluded.
+    """
+    if _GIT_RESET_HARD_RE.search(command):
+        return DestructiveOp(verb="reset --hard", paths=(), sweeps_whole_tree=True)
+    if _GIT_STASH_RE.search(command):
+        return DestructiveOp(verb="stash", paths=(), sweeps_whole_tree=True)
+    if _GIT_CHECKOUT_RE.search(command):
+        paths = _extract_path_args(command)
+        # A bare ``git checkout <branch>`` (no path that looks like a file) is
+        # not in scope; only a path argument can overwrite a working file.
+        return DestructiveOp(verb="checkout", paths=paths, sweeps_whole_tree=False) if paths else None
+    if _GIT_RESTORE_RE.search(command):
+        paths = _extract_path_args(command)
+        return DestructiveOp(verb="restore", paths=paths, sweeps_whole_tree=False) if paths else None
+    return None
+
+
+# --------------------------------------------------------------------------- #
+# Verdict
+# --------------------------------------------------------------------------- #
+
+
+@dataclass(frozen=True, slots=True)
+class OverwriteVerdict:
+    """Whether a destructive op would clobber a dirty tracked config/dotfile."""
+
+    blocked: bool
+    verb: str = ""
+    config_paths: tuple[str, ...] = field(default=())
+    reason: str = ""
+
+
+def _config_paths_at_risk(repo: Path, candidate_paths: tuple[str, ...]) -> list[str]:
+    """Subset of *candidate_paths* that are tracked, dirty config/dotfiles."""
+    at_risk: list[str] = []
+    for path in candidate_paths:
+        if not is_config_path(path):
+            continue
+        if not is_tracked(repo, path):
+            continue
+        if has_uncommitted_changes(repo, path):
+            at_risk.append(path)
+    return at_risk
+
+
+def _dirty_tracked_config_files(repo: Path) -> list[str]:
+    """Every tracked config/dotfile in *repo* with uncommitted changes.
+
+    Used for the whole-tree verbs (``reset --hard`` / ``stash``) that name no
+    path: any dirty tracked config file in the repo is at risk.
+    """
+    rc, out = _git(repo, "status", "--porcelain")
+    if rc != 0 or not out:
+        return []
+    at_risk: list[str] = []
+    for line in out.splitlines():
+        # Porcelain v1: "XY <path>" (rename "XY <old> -> <new>").
+        rest = line[3:].strip()
+        path = rest.split(" -> ")[-1].strip().strip('"')
+        if path and is_config_path(path):
+            at_risk.append(path)
+    return at_risk
+
+
+def evaluate(command: str, repo: Path) -> OverwriteVerdict:
+    """Decide whether *command* would destroy a dirty tracked config/dotfile in *repo*.
+
+    Returns a blocking :class:`OverwriteVerdict` when the parsed destructive op
+    would overwrite at least one tracked config/dotfile that has uncommitted
+    working-tree changes. Everything else — a non-destructive command, a
+    destructive op on a source file, a config file with no uncommitted changes,
+    or an untracked file — returns ``blocked=False``.
+    """
+    op = parse_destructive_op(command)
+    if op is None:
+        return OverwriteVerdict(blocked=False)
+    toplevel = _toplevel(repo)
+    if toplevel is None:
+        return OverwriteVerdict(blocked=False)
+
+    if op.sweeps_whole_tree:
+        at_risk = _dirty_tracked_config_files(toplevel)
+    else:
+        at_risk = _config_paths_at_risk(toplevel, op.paths)
+
+    if not at_risk:
+        return OverwriteVerdict(blocked=False)
+    return OverwriteVerdict(
+        blocked=True,
+        verb=op.verb,
+        config_paths=tuple(at_risk),
+        reason=format_block_reason(op.verb, at_risk),
+    )
+
+
+def format_block_reason(verb: str, config_paths: list[str]) -> str:
+    """Render the actionable refusal message for the hook layer."""
+    files = ", ".join(f"`{p}`" for p in config_paths)
+    return (
+        f"BLOCKED: `git {verb}` would discard UNCOMMITTED working-tree changes to a tracked "
+        f"config/dotfile ({files}). A live dotfile's uncommitted edits are almost always newer "
+        f"than the committed version — restoring HEAD over them is silent data loss with no "
+        f"recovery unless the edits were staged. Read the current content first and confirm the "
+        f"loss is intended. If it genuinely is, snapshot the file aside (`cp <file> <file>.bak`) "
+        f"then append `[config-overwrite-ok: <reason>]` to the command to proceed."
+    )
