diff --git a/tests/teatree_loop/test_statusline_staleness.py b/tests/teatree_loop/test_statusline_staleness.py
new file mode 100644
index 0000000000..96054f2270
--- /dev/null
+++ b/tests/teatree_loop/test_statusline_staleness.py
@@ -0,0 +1,69 @@
+"""``staleness_banner`` — the shared read-path freshness gate (souliane/teatree#2625).
+
+The hook (``hooks/scripts/statusline.sh``) and ``t3 loop status`` both prepend
+this banner when the last-rendered statusline is older than the stale cutoff, so
+a dead-or-long-not-ticked loop never renders a confident, frozen loop line with
+no warning. The helper is the single home for the cutoff and the wording.
+"""
+
+import json
+from pathlib import Path
+
+from teatree.loop.statusline_staleness import STALE_FLOOR_SECONDS, staleness_banner
+
+
+def _write_meta(path: Path, *, rendered_at: int, cadence: int = 720) -> Path:
+    meta = path / "tick-meta.json"
+    meta.write_text(json.dumps({"rendered_at": rendered_at, "cadence": cadence}), encoding="utf-8")
+    return meta
+
+
+class TestStalenessBanner:
+    def test_fresh_render_yields_no_banner(self, tmp_path: Path) -> None:
+        meta = _write_meta(tmp_path, rendered_at=1000, cadence=720)
+        assert staleness_banner(meta, now=1030) == ""
+
+    def test_stale_render_yields_banner_with_minutes(self, tmp_path: Path) -> None:
+        # 3 * cadence (2160s) old → 36 minutes.
+        meta = _write_meta(tmp_path, rendered_at=1000, cadence=720)
+        banner = staleness_banner(meta, now=1000 + 2160)
+        assert "statusline stale" in banner
+        assert "36m" in banner
+        assert "t3 loop tick" in banner
+
+    def test_just_under_cutoff_is_not_stale(self, tmp_path: Path) -> None:
+        # Cutoff is max(2*cadence, STALE_FLOOR_SECONDS). cadence 720 → 1440s.
+        meta = _write_meta(tmp_path, rendered_at=1000, cadence=720)
+        assert staleness_banner(meta, now=1000 + 1439) == ""
+
+    def test_just_over_cutoff_is_stale(self, tmp_path: Path) -> None:
+        meta = _write_meta(tmp_path, rendered_at=1000, cadence=720)
+        assert "statusline stale" in staleness_banner(meta, now=1000 + 1441)
+
+    def test_cutoff_floor_applies_for_tiny_cadence(self, tmp_path: Path) -> None:
+        # 2*cadence (120s) is below the floor, so the floor governs.
+        meta = _write_meta(tmp_path, rendered_at=1000, cadence=60)
+        assert staleness_banner(meta, now=1000 + (STALE_FLOOR_SECONDS - 1)) == ""
+        assert "statusline stale" in staleness_banner(meta, now=1000 + (STALE_FLOOR_SECONDS + 1))
+
+    def test_missing_rendered_at_falls_back_to_file_mtime(self, tmp_path: Path) -> None:
+        meta = tmp_path / "tick-meta.json"
+        meta.write_text(json.dumps({"cadence": 720}), encoding="utf-8")
+        import os  # noqa: PLC0415
+
+        old = 1_000_000
+        os.utime(meta, (old, old))
+        assert "statusline stale" in staleness_banner(meta, now=old + 4000)
+        assert staleness_banner(meta, now=old + 30) == ""
+
+    def test_missing_file_fails_open_silent(self, tmp_path: Path) -> None:
+        assert staleness_banner(tmp_path / "absent.json", now=9999) == ""
+
+    def test_unreadable_json_fails_open_silent(self, tmp_path: Path) -> None:
+        meta = tmp_path / "tick-meta.json"
+        meta.write_text("{not json", encoding="utf-8")
+        # With a fresh mtime the broken JSON cannot prove staleness → silent.
+        import os  # noqa: PLC0415
+
+        os.utime(meta, None)
+        assert staleness_banner(meta, now=int(meta.stat().st_mtime) + 10) == ""
