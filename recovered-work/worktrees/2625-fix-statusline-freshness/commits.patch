diff --git a/src/teatree/loop/statusline_staleness.py b/src/teatree/loop/statusline_staleness.py
new file mode 100644
index 0000000000..533c16a602
--- /dev/null
+++ b/src/teatree/loop/statusline_staleness.py
@@ -0,0 +1,63 @@
+"""Read-path freshness gate for the statusline (souliane/teatree#2625).
+
+The statusline file is regenerated only by a tick's ``render_phase``. Both
+readers — ``hooks/scripts/statusline.sh`` and ``t3 loop status`` — display the
+pre-rendered file verbatim, so a dead or long-not-ticked loop renders a
+confident but frozen loop line with no warning. This helper is the single home
+for the stale cutoff and the banner wording both readers prepend, so the shell
+hook and the CLI agree.
+
+The cutoff is ``max(2 * cadence, STALE_FLOOR_SECONDS)``: two missed ticks, or a
+floor so a tiny cadence cannot make every render look stale. The age comes from
+``tick-meta.json``'s ``rendered_at`` field, falling back to the file's mtime so
+the gate works even before that field exists in an older sidecar.
+
+Fail-open by construction: a missing file, missing field, or unreadable JSON
+yields no banner — the hook's crash-proof-and-fast contract (``hooks/CLAUDE.md``)
+must never be broken by this read.
+"""
+
+import json
+from pathlib import Path
+
+STALE_FLOOR_SECONDS = 300
+
+
+def _stale_cutoff(cadence: int) -> int:
+    return max(2 * cadence, STALE_FLOOR_SECONDS)
+
+
+def _age_minutes(seconds: int) -> int:
+    return seconds // 60
+
+
+def staleness_banner(meta_path: Path, *, now: int) -> str:
+    """Return a RED stale-statusline banner line, or ``""`` when fresh/unknown.
+
+    *meta_path* is the ``tick-meta.json`` sidecar. *now* is the current epoch
+    second. The banner fires when ``now - rendered_at`` exceeds the cutoff for
+    the recorded cadence; ``rendered_at`` falls back to the file's mtime when
+    the field is absent. Any read/parse error degrades to ``""`` (fail-open).
+    """
+    try:
+        stat = meta_path.stat()
+    except OSError:
+        return ""
+    cadence = 720
+    rendered_at: float = stat.st_mtime
+    try:
+        data = json.loads(meta_path.read_text(encoding="utf-8"))
+    except (OSError, ValueError):
+        data = {}
+    if isinstance(data, dict):
+        raw_cadence = data.get("cadence")
+        if isinstance(raw_cadence, int) and raw_cadence > 0:
+            cadence = raw_cadence
+        raw_rendered = data.get("rendered_at")
+        if isinstance(raw_rendered, int):
+            rendered_at = raw_rendered
+
+    age = now - int(rendered_at)
+    if age <= _stale_cutoff(cadence):
+        return ""
+    return f"\033[1;31m⚠ statusline stale — last tick {_age_minutes(age)}m ago (run `t3 loop tick`)\033[0m"
