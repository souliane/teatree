--- a/hooks/scripts/statusline.sh
+++ b/hooks/scripts/statusline.sh
@@ -471,6 +471,36 @@ effort_from_settings() {
 
 g_updates="$_freshness_segment"
 
+# Read-path freshness gate (#2625): the zones file is regenerated only by a
+# tick's render_phase, so a dead or long-not-ticked loop renders a confident,
+# frozen loop line. Compute the render age from tick-meta.json's `rendered_at`
+# (falling back to the meta file's mtime so it works before that field exists)
+# and prepend a RED stale banner past the cutoff. The cutoff and wording match
+# teatree.loop.statusline_staleness so the hook and `t3 loop status` agree.
+# Fail-open by construction: missing jq, field, or unreadable meta → no banner.
+_stale_banner=""
+if [ -r "$_tick_meta" ]; then
+    _now=${_now:-$(date +%s)}
+    _meta_cadence=""
+    _meta_rendered=""
+    if command -v jq >/dev/null 2>&1; then
+        _meta_cadence=$(jq -r '.cadence // empty' "$_tick_meta" 2>/dev/null)
+        _meta_rendered=$(jq -r '.rendered_at // empty' "$_tick_meta" 2>/dev/null)
+    fi
+    [ -n "$_meta_cadence" ] && [ "$_meta_cadence" -gt 0 ] 2>/dev/null || _meta_cadence=720
+    if [ -z "$_meta_rendered" ] || ! [ "$_meta_rendered" -gt 0 ] 2>/dev/null; then
+        _meta_rendered=$(stat -c %Y "$_tick_meta" 2>/dev/null || stat -f %m "$_tick_meta" 2>/dev/null || echo 0)
+    fi
+    if [ "$_meta_rendered" -gt 0 ] 2>/dev/null; then
+        _cutoff=$(( 2 * _meta_cadence ))
+        [ "$_cutoff" -lt 300 ] && _cutoff=300
+        _age=$(( _now - _meta_rendered ))
+        if [ "$_age" -gt "$_cutoff" ] 2>/dev/null; then
+            _stale_banner="${_RED}⚠ statusline stale — last tick $(( _age / 60 ))m ago (run \`t3 loop tick\`)${_RST}"
+        fi
+    fi
+fi
+
 # Agent-Teams roster: the live mates of the team THIS session leads, rendered
 # compactly so the lead sees who is on the bench without the harness's inline
 # ``@mate · shift+↑/↓`` switcher being the only surface. The team config lives
@@ -570,6 +600,9 @@ effort_from_settings() {
     fi
 fi
 
+# The read-path freshness banner (#2625) leads every line so a dead loop is
+# never mistaken for a fresh render; silent on a fresh / missing / unreadable meta.
+[ -n "$_stale_banner" ] && printf '%s\n' "$_stale_banner"
