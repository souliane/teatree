+class TestStaleStatuslineBanner:
+    """A stale read-path freshness banner when the last tick is too old (#2625).
+
+    The hook displays the pre-rendered zones file verbatim, so a dead or
+    long-not-ticked loop renders a confident, frozen loop line with no warning.
+    The banner reads ``tick-meta.json``'s ``rendered_at`` (cutoff =
+    ``max(2*cadence, 300s)``) and prepends a RED ``⚠ statusline stale`` line —
+    age-gated so a fresh render shows nothing, fail-open on a missing/broken meta.
+    """
+
+    def test_stale_meta_prepends_banner_with_minutes(self, tmp_path: Path) -> None:
+        state_dir = tmp_path / "state"
+        state_dir.mkdir()
+        statusline_file = tmp_path / "statusline.txt"
+        statusline_file.write_text("tick 11m\n", encoding="utf-8")
+        # 3 * cadence old → 36m, well past the max(2*cadence, 300) cutoff.
+        rendered_at = int(time.time()) - 3 * 720
+        (tmp_path / "tick-meta.json").write_text(
+            json.dumps({"rendered_at": rendered_at, "cadence": 720}), encoding="utf-8"
+        )
+
+        result = _run(
+            {"session_id": "s-stale", "model": {"display_name": "Claude Opus"}},
+            state_dir=state_dir,
+            statusline_file=statusline_file,
+        )
+
+        assert result.returncode == 0, result.stderr
+        plain = _strip_ansi(result.stdout)
+        assert "statusline stale" in plain, plain
+        assert "36m" in plain, plain
+        assert "t3 loop tick" in plain, plain
+        # The frozen loop line is still shown — the banner is additive.
+        assert "tick 11m" in plain, plain
+        # Painted RED so a dead loop is impossible to mistake for a fresh one.
+        assert "\033[1;31m" in result.stdout, "expected red SGR for the stale banner"
+
+    def test_fresh_meta_shows_no_banner(self, tmp_path: Path) -> None:
+        state_dir = tmp_path / "state"
+        state_dir.mkdir()
+        statusline_file = tmp_path / "statusline.txt"
+        statusline_file.write_text("tick 11m\n", encoding="utf-8")
+        # 30s old → far under the cutoff: proves the banner is age-gated, not always-on.
+        (tmp_path / "tick-meta.json").write_text(
+            json.dumps({"rendered_at": int(time.time()) - 30, "cadence": 720}), encoding="utf-8"
+        )
+
+        result = _run(
+            {"session_id": "s-fresh", "model": {"display_name": "Claude Opus"}},
+            state_dir=state_dir,
+            statusline_file=statusline_file,
+        )
+
+        assert result.returncode == 0, result.stderr
+        plain = _strip_ansi(result.stdout)
+        assert "statusline stale" not in plain, plain
+        assert "tick 11m" in plain, plain
+
+    def test_missing_meta_fails_open_silent(self, tmp_path: Path) -> None:
+        state_dir = tmp_path / "state"
+        state_dir.mkdir()
+        statusline_file = tmp_path / "statusline.txt"
+        statusline_file.write_text("tick 11m\n", encoding="utf-8")
+        # No tick-meta.json at all → fail open, no banner, rest still renders.
+
+        result = _run(
+            {"session_id": "s-nometa", "model": {"display_name": "Claude Opus"}},
+            state_dir=state_dir,
+            statusline_file=statusline_file,
+        )
+
+        assert result.returncode == 0, result.stderr
+        plain = _strip_ansi(result.stdout)
+        assert "statusline stale" not in plain, plain
+        assert "model=Claude Opus" in plain, plain
+
