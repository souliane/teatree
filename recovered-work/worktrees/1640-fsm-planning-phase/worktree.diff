new file mode 100644
index 0000000000..b3eba0192b
--- /dev/null
+++ tests/test_hook_router_plan_artifact_gate.py
@@ -0,0 +1,128 @@
+"""The implementation-intent plan gate reads the plan-artifact signal (#1640).
+
+Phase 0 of #1640 repoints ``handle_enforce_plan_gate_on_task_create`` so its
+satisfied-signal is the plan artifact (written by ``lifecycle
+record-plan-artifact``), NOT the ``teatree-plan`` backlog-prioritization skill
+timestamp (the #1640 bug — ``subagent_safe: false``, unearnable unattended).
+
+The gate stays default-OFF (opt-in via ``[teatree]
+agent_plan_gate_on_task_create_enabled = true``). When armed it fires only for
+IMPLEMENTATION-INTENT dispatches; cold-review / read-only / cleanup / merge
+dispatches are exempt.
+"""
+
+import json
+import time
+from pathlib import Path
+
+import pytest
+
+import hooks.scripts.hook_router as router
+from hooks.scripts.hook_router import handle_enforce_plan_gate_on_task_create
+
+
+@pytest.fixture
+def gate_env(tmp_path: Path, monkeypatch: pytest.MonkeyPatch) -> Path:
+    xdg = tmp_path / "xdg-data"
+    xdg.mkdir(parents=True, exist_ok=True)
+    monkeypatch.setenv("XDG_DATA_HOME", str(xdg))
+    monkeypatch.delenv("TEATREE_PLAN_GATE_WINDOW_MINUTES", raising=False)
+    return xdg / "teatree" / "last-plan-artifact-ts"
+
+
+def _seed_teatree_toml(body: str) -> None:
+    home = Path.home()
+    home.mkdir(parents=True, exist_ok=True)
+    (home / ".teatree.toml").write_text(body, encoding="utf-8")
+
+
+def _arm_gate() -> None:
+    _seed_teatree_toml("[teatree]\nagent_plan_gate_on_task_create_enabled = true\n")
+
+
+def _task_create(subject: str = "implement feature foo", description: str = "") -> dict:
+    return {"session_id": "sess-1", "task_subject": subject, "task_description": description}
+
+
+def _write_artifact_ts(ts_file: Path, ts: float) -> None:
+    ts_file.parent.mkdir(parents=True, exist_ok=True)
+    ts_file.write_text(str(int(ts)), encoding="utf-8")
+
+
+class TestDefaultOff:
+    def test_no_config_allows(self, gate_env: Path) -> None:
+        assert not gate_env.is_file()
+        assert handle_enforce_plan_gate_on_task_create(_task_create()) is False
+
+    def test_flag_unset_allows(self, gate_env: Path) -> None:
+        _seed_teatree_toml("[teatree]\nskill_loading_gate_enabled = true\n")
+        assert handle_enforce_plan_gate_on_task_create(_task_create()) is False
+
+    def test_broken_config_disabled(self, gate_env: Path) -> None:
+        _seed_teatree_toml("this is not = valid toml [[[\n")
+        assert handle_enforce_plan_gate_on_task_create(_task_create()) is False
+
+
+class TestArmedReadsPlanArtifact:
+    def test_armed_implementation_intent_denies_without_artifact(self, gate_env: Path, capsys) -> None:
+        _arm_gate()
+        assert not gate_env.is_file()
+        blocked = handle_enforce_plan_gate_on_task_create(_task_create("implement the new exporter"))
+        assert blocked is True
+        out = json.loads(capsys.readouterr().out)
+        assert out["continue"] is False
+        assert "PLAN-GATE ENFORCEMENT (TaskCreated)" in out["stopReason"]
+        # The reason must point at the artifact signal, not the teatree-plan skill.
+        assert "plan artifact" in out["stopReason"].lower()
+        assert "teatree-plan" not in out["stopReason"]
+
+    def test_armed_implementation_intent_allows_with_fresh_artifact(self, gate_env: Path) -> None:
+        _arm_gate()
+        _write_artifact_ts(gate_env, time.time() - 5 * 60)
+        assert handle_enforce_plan_gate_on_task_create(_task_create("implement the new exporter")) is False
+
+    def test_stale_artifact_blocks(self, gate_env: Path, capsys) -> None:
+        _arm_gate()
+        _write_artifact_ts(gate_env, time.time() - 35 * 60)
+        assert handle_enforce_plan_gate_on_task_create(_task_create("implement feature")) is True
+        capsys.readouterr()
+
+    def test_teatree_plan_skill_timestamp_does_not_satisfy(self, gate_env: Path, capsys) -> None:
+        # The #1640 bug: the teatree-plan skill marker must NOT satisfy the
+        # implementation-intent gate. Write the OLD skill-timestamp marker and
+        # confirm the gate still blocks (it reads only the plan-artifact marker).
+        _arm_gate()
+        skill_ts = router._plan_skill_timestamp_file()
+        skill_ts.parent.mkdir(parents=True, exist_ok=True)
+        skill_ts.write_text(str(int(time.time())), encoding="utf-8")
+        assert handle_enforce_plan_gate_on_task_create(_task_create("implement feature")) is True
+        capsys.readouterr()
+
+
+class TestExemptDispatches:
+    @pytest.mark.parametrize(
+        "subject",
+        [
+            "cold-review PR 42",
+            "review the code on the open MR",
+            "read-only investigation of the loop scanner",
+            "cleanup merged worktrees and stale branches",
+            "merge the green PR via the keystone",
+        ],
+    )
+    def test_exempt_dispatch_allows_without_artifact(self, gate_env: Path, subject: str) -> None:
+        _arm_gate()
+        assert not gate_env.is_file()
+        assert handle_enforce_plan_gate_on_task_create(_task_create(subject)) is False
+
+
+class TestSkipToken:
+    def test_skip_token_allows(self, gate_env: Path) -> None:
+        _arm_gate()
+        data = _task_create("[skip-plan-gate: trivial] implement the tiny fix")
+        assert handle_enforce_plan_gate_on_task_create(data) is False
+
+    def test_window_zero_disables_freshness(self, gate_env: Path, monkeypatch: pytest.MonkeyPatch) -> None:
+        _arm_gate()
+        monkeypatch.setenv("TEATREE_PLAN_GATE_WINDOW_MINUTES", "0")
+        assert handle_enforce_plan_gate_on_task_create(_task_create("implement feature")) is False
