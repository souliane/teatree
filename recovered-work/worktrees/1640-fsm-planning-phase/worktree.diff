index 0000000000..bc3f945338
--- /dev/null
+++ tests/teatree_core/test_plan_artifact.py
@@ -0,0 +1,40 @@
+"""The plan-artifact 'planned' signal (#1640 Phase 0).
+
+``record_plan_artifact`` stamps ``ticket.extra['plan_artifact']`` (skill name +
+path + UTC ISO timestamp) so the implementation-intent plan gate can attest that
+an implementation plan was produced — replacing the ``teatree-plan`` skill
+timestamp, which was backlog-prioritization (the #1640 bug). Mirrors
+``record_review_skill_run`` exactly.
+"""
+
+from django.core.management import call_command
+from django.test import TestCase
+
+from teatree.core.models import Ticket
+
+
+class TestRecordPlanArtifact(TestCase):
+    def test_stores_skill_path_and_iso_timestamp_on_extra(self) -> None:
+        ticket = Ticket.objects.create(overlay="t3-teatree", state=Ticket.State.STARTED)
+        ticket.record_plan_artifact("architecture-design", "/tmp/plan-7.md")
+        ticket.refresh_from_db()
+        artifact = ticket.extra["plan_artifact"]
+        assert artifact["skill"] == "architecture-design"
+        assert artifact["path"] == "/tmp/plan-7.md"
+        assert artifact["recorded_at"].endswith("+00:00") or artifact["recorded_at"].endswith("Z")
+
+    def test_record_plan_artifact_command_stamps_extra(self) -> None:
+        ticket = Ticket.objects.create(overlay="t3-teatree", state=Ticket.State.STARTED)
+        call_command("lifecycle", "record-plan-artifact", str(ticket.pk), "writing-plans", "/tmp/plan.md")
+        ticket.refresh_from_db()
+        artifact = ticket.extra["plan_artifact"]
+        assert artifact["skill"] == "writing-plans"
+        assert artifact["path"] == "/tmp/plan.md"
+
+    def test_record_plan_artifact_round_trips_through_validated_extra(self) -> None:
+        # The stamp must survive the validated_ticket_extra allow-list filter
+        # (the key must be a recognised TicketExtra field).
+        ticket = Ticket.objects.create(overlay="t3-teatree", state=Ticket.State.STARTED)
+        ticket.record_plan_artifact("architecture-design", "/tmp/p.md")
+        ticket.refresh_from_db()
+        assert ticket._extra().get("plan_artifact", {}).get("skill") == "architecture-design"
diff --git tests/teatree_core/test_planning_phase.py tests/teatree_core/test_planning_phase.py
new file mode 100644
index 0000000000..2413a55bea
--- /dev/null
+++ tests/teatree_core/test_planning_phase.py
@@ -0,0 +1,188 @@
+"""Planning as an FSM phase with spawn-on-transition (#1640).
+
+Drives the loop dispatch / claim path and the per-phase auto-dispatch chain to
+assert the planning phase is woven into the existing
+``Ticket.<transition>() → schedule_<phase>() → claim-next → Task.complete()``
+chain:
+
+a) starting a ticket (provision worker) schedules a PENDING planning Task,
+b) ``claim-next`` emits it with the planner subagent,
+c) completing the planning Task advances STARTED→PLANNED and schedules coding,
+d) the code→test→review→ship chain still works unchanged afterward.
+"""
+
+import json
+from io import StringIO
+from pathlib import Path
+from unittest.mock import MagicMock, patch
+
+import pytest
+from django.core.management import call_command
+from django.test import TestCase
+
+from teatree.core import tasks as tasks_mod
+from teatree.core.models import Session, Task, Ticket
+from tests.teatree_core.models._shared import _attach_shippable_worktree, _complete_phase_task
+
+
+def _start_with_provision_scheduling_planning(test_case: TestCase, ticket: Ticket) -> None:
+    """Drive ``start()`` and let the worker schedule the planning task."""
+
+    def fake_enqueue(ticket_id: int) -> None:
+        target = Ticket.objects.get(pk=ticket_id)
+        if target.state == Ticket.State.STARTED:
+            target.schedule_planning()
+
+    fake_task = MagicMock()
+    fake_task.enqueue.side_effect = fake_enqueue
+    with (
+        patch.object(tasks_mod, "execute_provision", fake_task),
+        test_case.captureOnCommitCallbacks(execute=True),
+    ):
+        ticket.start()
+        ticket.save()
+
+
+class TestStartSchedulesPlanning(TestCase):
+    @pytest.fixture(autouse=True)
+    def _inject_tmp_path(self, tmp_path: Path) -> None:
+        self._tmp_path = tmp_path
+
+    def test_start_provisions_then_schedules_planning_task(self) -> None:
+        ticket = Ticket.objects.create(issue_url="https://example.com/issues/1")
+        ticket.scope()
+        ticket.save()
+
+        _start_with_provision_scheduling_planning(self, ticket)
+
+        ticket.refresh_from_db()
+        task = ticket.tasks.get(phase="planning")
+        assert task.execution_target == Task.ExecutionTarget.HEADLESS
+        assert task.session.agent_id == "planning"
+        assert task.status == Task.Status.PENDING
+        assert ticket.state == Ticket.State.STARTED
+        # No coding task yet — coding is scheduled by plan(), not by start().
+        assert not ticket.tasks.filter(phase="coding").exists()
+
+    def test_claim_next_emits_planning_task_with_planner_subagent(self) -> None:
+        ticket = Ticket.objects.create(issue_url="https://example.com/issues/2")
+        ticket.scope()
+        ticket.save()
+        _start_with_provision_scheduling_planning(self, ticket)
+
+        out = StringIO()
+        call_command("loop_dispatch", "claim-next", "--json", stdout=out)
+        payload = json.loads(out.getvalue())
+
+        assert len(payload) == 1
+        entry = payload[0]
+        assert entry["phase"] == "planning"
+        assert entry["subagent"] == "t3:planner"
+        assert entry["issue_url"] == "https://example.com/issues/2"
+
+    def test_completing_planning_task_advances_to_planned_and_schedules_coding(self) -> None:
+        ticket = Ticket.objects.create(issue_url="https://example.com/issues/3")
+        ticket.scope()
+        ticket.save()
+        _start_with_provision_scheduling_planning(self, ticket)
+
+        _complete_phase_task(ticket, "planning")
+
+        ticket.refresh_from_db()
+        assert ticket.state == Ticket.State.PLANNED
+        coding = ticket.tasks.get(phase="coding")
+        assert coding.status == Task.Status.PENDING
+        assert coding.session.agent_id == "coding"
+
+    def test_full_chain_planning_through_shipping_still_works(self) -> None:
+        ticket = Ticket.objects.create(issue_url="https://example.com/issues/4")
+        _attach_shippable_worktree(ticket, self._tmp_path)
+        ticket.scope()
+        ticket.save()
+        _start_with_provision_scheduling_planning(self, ticket)
+
+        _complete_phase_task(ticket, "planning")
+        ticket.refresh_from_db()
+        assert ticket.state == Ticket.State.PLANNED
+
+        _complete_phase_task(ticket, "coding")
+        ticket.refresh_from_db()
+        assert ticket.state == Ticket.State.CODED
+
+        _complete_phase_task(ticket, "testing")
+        ticket.refresh_from_db()
+        assert ticket.state == Ticket.State.TESTED
+
+        _complete_phase_task(ticket, "reviewing")
+        ticket.refresh_from_db()
+        assert ticket.state == Ticket.State.REVIEWED
+
+        _complete_phase_task(ticket, "shipping")
+        ticket.refresh_from_db()
+        assert ticket.state == Ticket.State.SHIPPED
+
+
+class TestPlanTransition(TestCase):
+    def test_plan_advances_started_to_planned_and_schedules_coding(self) -> None:
+        ticket = Ticket.objects.create(issue_url="https://example.com/issues/5")
+        ticket.scope()
+        ticket.save()
+        ticket.start()
+        ticket.save()
+
+        ticket.plan()
+        ticket.save()
+
+        assert ticket.state == Ticket.State.PLANNED
+        assert ticket.tasks.filter(phase="coding", status=Task.Status.PENDING).exists()
+
+    def test_schedule_planning_creates_headless_task_on_fresh_session(self) -> None:
+        ticket = Ticket.objects.create(issue_url="https://example.com/issues/6")
+        task = ticket.schedule_planning()
+
+        assert task.phase == "planning"
+        assert task.execution_target == Task.ExecutionTarget.HEADLESS
+        assert "implementation plan" in task.execution_reason.lower()
+        assert task.session.agent_id == "planning"
+
+    def test_apply_phase_transition_fires_plan_from_started(self) -> None:
+        ticket = Ticket.objects.create(issue_url="https://example.com/issues/7")
+        ticket.scope()
+        ticket.save()
+        ticket.start()
+        ticket.save()
+        session = Session.objects.create(ticket=ticket, agent_id="planning")
+        task = Task.objects.create(
+            ticket=ticket,
+            session=session,
+            phase="planning",
+            status=Task.Status.COMPLETED,
+        )
+
+        fired = task._apply_phase_transition()
+
+        ticket.refresh_from_db()
+        assert fired is True
+        assert ticket.state == Ticket.State.PLANNED
+
+    def test_coding_arm_requires_planned_state(self) -> None:
+        # A coding task completing on a STARTED ticket (planning skipped) must
+        # NOT advance — the loop coding arm guards on PLANNED.
+        ticket = Ticket.objects.create(issue_url="https://example.com/issues/8")
+        ticket.scope()
+        ticket.save()
+        ticket.start()
+        ticket.save()
+        session = Session.objects.create(ticket=ticket, agent_id="coding")
+        task = Task.objects.create(
+            ticket=ticket,
+            session=session,
+            phase="coding",
+            status=Task.Status.COMPLETED,
+        )
+
+        fired = task._apply_phase_transition()
+
+        ticket.refresh_from_db()
+        assert fired is False
+        assert ticket.state == Ticket.State.STARTED
