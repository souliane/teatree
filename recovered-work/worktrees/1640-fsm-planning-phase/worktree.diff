+"""The plan-artifact wall-clock marker the implementation-intent gate reads (#1640).
+
+``lifecycle record-plan-artifact`` writes a POSIX timestamp here when a plan is
+produced; the ``TaskCreated`` plan gate (``hook_router``) reads it as the
+satisfied-signal for implementation-intent dispatches, replacing the
+``teatree-plan`` backlog-prioritization skill timestamp (#1640 bug). The hook
+mirrors this path resolution rather than importing it, to stay independent of
+the core package (same convention as the ``last-plan-skill-ts`` marker).
+"""
+
+import os
+import time
+from pathlib import Path
+
+_MARKER_NAME = "last-plan-artifact-ts"
+
+
+def plan_artifact_marker_path() -> Path:
+    """Resolve the marker: ``XDG_DATA_HOME/teatree`` → ``~/.local/share/teatree``."""
+    xdg = os.environ.get("XDG_DATA_HOME", "").strip()
+    base = Path(xdg) if xdg else Path.home() / ".local" / "share"
+    return base / "teatree" / _MARKER_NAME
+
+
+def touch_plan_artifact_marker() -> None:
+    """Write the current POSIX time so the freshness window sees a fresh plan."""
+    path = plan_artifact_marker_path()
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(str(int(time.time())), encoding="utf-8")
