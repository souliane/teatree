+    def prune_obsolete(self) -> int:
+        """Fail open tasks whose work item is already closed. Returns the count.
+
+        An open (PENDING or CLAIMED) task whose ``Ticket`` has reached a
+        terminal state (delivered or ignored) is obsolete: the work it was
+        queued for is done or abandoned, but nothing else completes it, so
+        ``PendingTasksScanner`` re-surfaces it on every tick and the loop's
+        task list grows without bound. This sweep transitions those rows to
+        FAILED so the pending list cannot accumulate orphaned work. Terminal
+        tasks (already COMPLETED / FAILED) are untouched; an active ticket's
+        open tasks are left to run.
+        """
+        from teatree.core.models.task import Task  # noqa: PLC0415
+        from teatree.core.models.ticket import Ticket  # noqa: PLC0415
+
+        with transaction.atomic():
+            return self.filter(
+                status__in=[Task.Status.PENDING, Task.Status.CLAIMED],
+                ticket__state__in=[Ticket.State.DELIVERED, Ticket.State.IGNORED],
+            ).update(
+                status=Task.Status.FAILED,
+                claimed_at=None,
+                claimed_by="",
+                lease_expires_at=None,
+                heartbeat_at=None,
+            )
+
+    def reap_stale_pending(self, *, max_age_hours: int = 24) -> int:
+        """Fail headless PENDING tasks no executor ever drained. Returns the count.
+
+        A headless task auto-enqueues to the django-tasks backend on
+        creation; a ``db_worker`` drains it. With no worker running (the
+        session-bound loop carries no daemon by design), those rows sit
+        PENDING indefinitely and ``PendingTasksScanner`` re-surfaces every
+        one each tick — the unbounded pending list the operator sees.
+        Beyond ``max_age_hours`` a never-drained PENDING headless task is
+        treated as failed-to-run and reaped, the PENDING twin of
+        ``reap_stale_claims``. The generous default deadline leaves a
+        slow-but-present worker ample time. Loop-dispatched and interactive
+        tasks are not auto-drained, so they are out of scope here.
+        """
+        from teatree.core.models.task import Task  # noqa: PLC0415
+
+        cutoff = timezone.now() - timedelta(hours=max_age_hours)
+        with transaction.atomic():
+            return self.filter(
+                status=Task.Status.PENDING,
+                execution_target=Task.ExecutionTarget.HEADLESS,
+                created_at__lt=cutoff,
+            ).update(
+                status=Task.Status.FAILED,
+                claimed_at=None,
+                claimed_by="",
+                lease_expires_at=None,
+                heartbeat_at=None,
+            )
