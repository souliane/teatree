+"""Regression test for ``core.0046_backfill_task_subject``.
+
+A Task created before the ``subject`` field existed has a blank subject;
+the statusline then fell back to the bare phase token (the unreadable
+``Task NN (short_describe)`` the operator reported). 0046 backfills a
+human-readable subject derived from the work item.
+"""
+
+import importlib
+
+from django.db import connection
+from django.db.migrations.executor import MigrationExecutor
+from django.test import TransactionTestCase
+
+_migration_module = importlib.import_module("teatree.core.migrations.0046_backfill_task_subject")
+
+
+class BackfillTaskSubjectMigrationTest(TransactionTestCase):
+    _BEFORE = ("core", "0045_task_created_at_task_subject")
+
+    def _migrate(self, target: tuple[str, str]) -> object:
+        executor = MigrationExecutor(connection)
+        executor.migrate([target])
+        executor.loader.build_graph()
+        return executor.loader.project_state([target]).apps
+
+    def _restore_head(self) -> None:
+        executor = MigrationExecutor(connection)
+        executor.loader.build_graph()
+        core_leaves = [node for node in executor.loader.graph.leaf_nodes() if node[0] == "core"]
+        executor.migrate(core_leaves)
+
+    def test_blank_subject_is_backfilled_from_ticket_title(self) -> None:
+        apps = self._migrate(self._BEFORE)
+        Ticket = apps.get_model("core", "Ticket")
+        Session = apps.get_model("core", "Session")
+        Task = apps.get_model("core", "Task")
+
+        ticket = Ticket.objects.create(
+            overlay="acme",
+            issue_url="https://example.com/issues/77",
+            extra={"issue_title": "Export pipeline rework"},
+        )
+        session = Session.objects.create(ticket=ticket, agent_id="agent")
+        task = Task.objects.create(ticket=ticket, session=session, phase="short_describe", subject="")
+
+        _migration_module.backfill_subject(apps, connection.schema_editor())
+
+        task.refresh_from_db()
+        assert task.subject == "#77 Export pipeline rework"
+
+        self._restore_head()
+
+    def test_falls_back_to_phase_when_no_title(self) -> None:
+        apps = self._migrate(self._BEFORE)
+        Ticket = apps.get_model("core", "Ticket")
+        Session = apps.get_model("core", "Session")
+        Task = apps.get_model("core", "Task")
+
+        ticket = Ticket.objects.create(overlay="acme", issue_url="dogfood-smoke://acme")
+        session = Session.objects.create(ticket=ticket, agent_id="agent")
+        task = Task.objects.create(ticket=ticket, session=session, phase="dogfood_smoke", subject="")
+
+        _migration_module.backfill_subject(apps, connection.schema_editor())
+
+        task.refresh_from_db()
+        assert task.subject == f"#{ticket.pk} dogfood_smoke"
+
+        self._restore_head()
