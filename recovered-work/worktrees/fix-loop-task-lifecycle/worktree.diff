@@ -0,0 +1,148 @@
+"""Task data + lifecycle regressions: open tasks drain, carry a subject, and prune.
+
+Guards the "loop task list totally broken" failure: scanner-created
+headless Tasks (``short_describe`` / ``dogfood_smoke`` /
+``architectural_review``) accumulated PENDING forever because no
+``db_worker`` drained the auto-enqueue queue in the session-bound loop,
+they carried no human description, and nothing pruned the ones whose work
+item was already closed.
+"""
+
+from datetime import timedelta
+
+from django.test import TestCase
+from django.utils import timezone
+
+from teatree.core.models import Session, Task, Ticket
+from teatree.loop.tick_recovery import _reap_stale_task_claims
+
+
+class TestTaskCarriesSubject(TestCase):
+    def test_created_task_has_non_empty_subject(self) -> None:
+        ticket = Ticket.objects.create(
+            overlay="acme",
+            issue_url="https://example.com/issues/42",
+            extra={"issue_title": "Improve the export pipeline"},
+        )
+        session = Session.objects.create(ticket=ticket, agent_id="agent")
+        task = Task.objects.create(ticket=ticket, session=session, phase="coding")
+
+        assert task.display_subject().strip()
+        assert task.display_subject() != "coding"
+
+    def test_explicit_subject_wins_over_derived(self) -> None:
+        ticket = Ticket.objects.create(overlay="acme", issue_url="https://example.com/issues/7")
+        session = Session.objects.create(ticket=ticket, agent_id="agent")
+        task = Task.objects.create(ticket=ticket, session=session, phase="coding", subject="Hand-written summary")
+
+        assert task.display_subject() == "Hand-written summary"
+
+
+class TestPruneObsolete(TestCase):
+    def test_prunes_pending_task_whose_ticket_is_terminal(self) -> None:
+        ticket = Ticket.objects.create(overlay="acme", state=Ticket.State.DELIVERED)
+        session = Session.objects.create(ticket=ticket, agent_id="agent")
+        stale = Task.objects.create(ticket=ticket, session=session, phase="coding", status=Task.Status.PENDING)
+
+        pruned = Task.objects.prune_obsolete()
+
+        stale.refresh_from_db()
+        assert pruned == 1
+        assert stale.status == Task.Status.FAILED
+
+    def test_keeps_pending_task_whose_ticket_is_active(self) -> None:
+        ticket = Ticket.objects.create(overlay="acme", state=Ticket.State.STARTED)
+        session = Session.objects.create(ticket=ticket, agent_id="agent")
+        live = Task.objects.create(ticket=ticket, session=session, phase="coding", status=Task.Status.PENDING)
+
+        pruned = Task.objects.prune_obsolete()
+
+        live.refresh_from_db()
+        assert pruned == 0
+        assert live.status == Task.Status.PENDING
+
+    def test_leaves_completed_tasks_alone(self) -> None:
+        ticket = Ticket.objects.create(overlay="acme", state=Ticket.State.DELIVERED)
+        session = Session.objects.create(ticket=ticket, agent_id="agent")
+        done = Task.objects.create(ticket=ticket, session=session, phase="coding", status=Task.Status.COMPLETED)
+
+        pruned = Task.objects.prune_obsolete()
+
+        done.refresh_from_db()
+        assert pruned == 0
+        assert done.status == Task.Status.COMPLETED
+
+    def test_tick_recovery_runs_prune(self) -> None:
+        ticket = Ticket.objects.create(overlay="acme", state=Ticket.State.IGNORED)
+        session = Session.objects.create(ticket=ticket, agent_id="agent")
+        stale = Task.objects.create(ticket=ticket, session=session, phase="coding", status=Task.Status.PENDING)
+
+        _reap_stale_task_claims()
+
+        stale.refresh_from_db()
+        assert stale.status == Task.Status.FAILED
+
+
+class TestReapStalePending(TestCase):
+    """A headless PENDING task no executor ever drained is reaped past its deadline."""
+
+    def _aged_pending_task(self, *, hours: int, phase: str = "dogfood_smoke") -> Task:
+        ticket = Ticket.objects.create(overlay="acme", issue_url=f"x://{phase}", state=Ticket.State.STARTED)
+        session = Session.objects.create(ticket=ticket, agent_id="agent")
+        task = Task.objects.create(
+            ticket=ticket,
+            session=session,
+            phase=phase,
+            execution_target=Task.ExecutionTarget.HEADLESS,
+            status=Task.Status.PENDING,
+        )
+        Task.objects.filter(pk=task.pk).update(created_at=timezone.now() - timedelta(hours=hours))
+        return task
+
+    def test_reaps_undrained_headless_pending_task(self) -> None:
+        task = self._aged_pending_task(hours=48)
+
+        reaped = Task.objects.reap_stale_pending(max_age_hours=24)
+
+        task.refresh_from_db()
+        assert reaped == 1
+        assert task.status == Task.Status.FAILED
+
+    def test_keeps_recent_pending_task(self) -> None:
+        task = self._aged_pending_task(hours=1)
+
+        reaped = Task.objects.reap_stale_pending(max_age_hours=24)
+
+        task.refresh_from_db()
+        assert reaped == 0
+        assert task.status == Task.Status.PENDING
+
+    def test_leaves_interactive_pending_task_alone(self) -> None:
+        ticket = Ticket.objects.create(overlay="acme", state=Ticket.State.STARTED)
+        session = Session.objects.create(ticket=ticket, agent_id="agent")
+        task = Task.objects.create(
+            ticket=ticket,
+            session=session,
+            phase="coding",
+            execution_target=Task.ExecutionTarget.INTERACTIVE,
+            status=Task.Status.PENDING,
+        )
+        Task.objects.filter(pk=task.pk).update(created_at=timezone.now() - timedelta(hours=48))
+
+        reaped = Task.objects.reap_stale_pending(max_age_hours=24)
+
+        task.refresh_from_db()
+        assert reaped == 0
+        assert task.status == Task.Status.PENDING
+
+
+class TestCompletedWorkUnitAdvancesTask(TestCase):
+    def test_complete_transitions_claimed_task_to_completed(self) -> None:
+        ticket = Ticket.objects.create(overlay="acme", state=Ticket.State.STARTED)
+        session = Session.objects.create(ticket=ticket, agent_id="agent")
+        task = Task.objects.create(ticket=ticket, session=session, phase="coding", status=Task.Status.CLAIMED)
+
+        task.complete(result_artifact_path="/tmp/artifact")
+
+        task.refresh_from_db()
+        assert task.status == Task.Status.COMPLETED

