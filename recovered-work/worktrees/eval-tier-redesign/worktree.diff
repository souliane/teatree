diff --git src/teatree/core/model_tier_resolver.py src/teatree/core/model_tier_resolver.py
new file mode 100644
index 0000000000..c50928edb0
--- /dev/null
+++ src/teatree/core/model_tier_resolver.py
@@ -0,0 +1,69 @@
+"""Resolve an abstract tier to a concrete model id — CACHED, fallback-safe.
+
+This is the read seam every spawn path (production phase dispatch + eval) calls.
+It is on the AGENT-SPAWN HOT PATH, so two invariants are load-bearing:
+
+- **Cached.** The whole ``{tier: model}`` map is read once and memoised, so a
+  spawn does not hit the DB. :func:`clear_tier_model_cache` (called by
+  ``ModelTier.objects.set_model``) invalidates it so a remap takes effect.
+- **Fallback-safe.** A missing table, a missing row, or ANY DB/bootstrap error
+  resolves to the built-in :data:`FALLBACK_TIER_MODELS` rather than raising — a
+  missing row can NEVER break agent spawning. The fallback is the ONLY place
+  besides the seed migration that names a concrete model id.
+"""
+
+from teatree.core.models.model_tier import BALANCED, FAST, FRONTIER
+
+#: The abstract tiers, strongest → weakest. The canonical key set every layer
+#: references; the table and the fallback map share exactly these keys.
+TIERS: tuple[str, ...] = (FRONTIER, BALANCED, FAST)
+
+#: The built-in fallback — the ONLY hardcoded tier→model map outside the seed
+#: migration. Used when the table/row is missing or unreadable so resolution
+#: never raises on the spawn path. The seed migration populates the table with
+#: these same values.
+FALLBACK_TIER_MODELS: dict[str, str] = {
+    FRONTIER: "claude-opus-4-8",
+    BALANCED: "claude-sonnet-4-6",
+    FAST: "claude-haiku-4-5",
+}
+
+_cache: dict[str, str] | None = None
+
+
+def clear_tier_model_cache() -> None:
+    """Drop the memoised tier→model map so the next read re-queries the table."""
+    global _cache  # noqa: PLW0603 — module-level memo, single owner.
+    _cache = None
+
+
+def _load_tier_models() -> dict[str, str]:
+    """Read the whole table into a ``{tier: model}`` map — fail-safe to empty.
+
+    Any DB error or unbootstrapped Django returns ``{}`` (the caller then falls
+    through to :data:`FALLBACK_TIER_MODELS`), so a resolution error degrades to
+    the safe built-in rather than raising on the spawn path.
+    """
+    try:
+        from teatree.core.models import ModelTier  # noqa: PLC0415
+
+        return ModelTier.objects.all_models()
+    except Exception:  # noqa: BLE001 — a spawn-path read must never raise.
+        return {}
+
+
+def resolve_tier_model(tier: str) -> str:
+    """Resolve *tier* to a concrete model id — table first, fallback always.
+
+    Reads the cached table map; a present row wins. A missing row falls back to
+    :data:`FALLBACK_TIER_MODELS`, and an unknown tier name falls back to the
+    ``balanced`` model — so the function ALWAYS returns a usable model id and
+    never raises, keeping the spawn path unbreakable.
+    """
+    global _cache  # noqa: PLW0603 — module-level memo, single owner.
+    if _cache is None:
+        _cache = _load_tier_models()
+    stored = _cache.get(tier)
+    if stored is not None:
+        return stored
+    return FALLBACK_TIER_MODELS.get(tier, FALLBACK_TIER_MODELS[BALANCED])

diff --git src/teatree/core/models/model_tier.py src/teatree/core/models/model_tier.py
new file mode 100644
index 0000000000..9ab04d3b13
--- /dev/null
+++ src/teatree/core/models/model_tier.py
@@ -0,0 +1,66 @@
+"""The single source of concrete model names — one row per abstract tier.
+
+Production phase dispatch, eval scenarios, and tests reference the abstract
+tiers ``frontier`` / ``balanced`` / ``fast``; this table is the ONLY place a
+concrete model id (``claude-opus-4-8`` ...) lives. A new model generation is a
+row remap — ``t3 model-tier set frontier <id>`` or a data migration — with zero
+edits to code, tests, or scenarios.
+
+The resolver (:mod:`teatree.core.model_tier_resolver`) reads this table CACHED so
+the agent-spawn hot path never hits the DB per spawn, and falls back to a
+hardcoded map when a row is missing, so resolution can never break spawning.
+"""
+
+from typing import ClassVar
+
+from django.db import models
+
+#: The abstract tiers — the canonical keys every other layer references. Ordered
+#: strongest → weakest (capability), matching the production phase floors.
+FRONTIER = "frontier"
+BALANCED = "balanced"
+FAST = "fast"
+
+
+class ModelTierManager(models.Manager["ModelTier"]):
+    """Read/write helpers for the tier → concrete-model table."""
+
+    def model_for(self, tier: str) -> str | None:
+        """Return the concrete model id stored for *tier*, or ``None`` when absent."""
+        row = self.filter(tier=tier).first()
+        return row.model if row is not None else None
+
+    def all_models(self) -> dict[str, str]:
+        """Return ``{tier: model}`` for every stored row (one query)."""
+        return dict(self.values_list("tier", "model"))
+
+    def set_model(self, tier: str, model: str) -> "ModelTier":
+        """Upsert the row for *tier* to *model* and clear the resolver cache.
+
+        The unique ``tier`` makes this an idempotent upsert. Clearing the cache
+        here is what makes ``t3 model-tier set`` take effect on the next spawn
+        without a process restart.
+        """
+        from teatree.core.model_tier_resolver import clear_tier_model_cache  # noqa: PLC0415
+
+        row, _ = self.update_or_create(tier=tier, defaults={"model": model})
+        clear_tier_model_cache()
+        return row
+
+
+class ModelTier(models.Model):
+    """One ``tier → concrete model id`` mapping; the SINGLE source of model names."""
+
+    tier = models.CharField(max_length=64, primary_key=True)
+    model = models.CharField(max_length=255)
+    created_at = models.DateTimeField(auto_now_add=True)
+    updated_at = models.DateTimeField(auto_now=True)
+
+    objects: ClassVar[ModelTierManager] = ModelTierManager()
+
+    class Meta:
+        db_table = "teatree_model_tier"
+        ordering: ClassVar = ["tier"]
+
+    def __str__(self) -> str:
+        return f"model-tier<{self.tier}={self.model}>"

diff --git tests/teatree_core/models/test_model_tier.py tests/teatree_core/models/test_model_tier.py
new file mode 100644
index 0000000000..bad7457f69
--- /dev/null
+++ tests/teatree_core/models/test_model_tier.py
@@ -0,0 +1,96 @@
+"""The ``ModelTier`` table is the SINGLE source of concrete model names.
+
+Everything else — production phase dispatch, eval scenarios, tests — references
+the abstract tiers ``frontier`` / ``balanced`` / ``fast``. A new model generation
+is a row remap, with zero code/test/scenario edits. The resolver is CACHED (no DB
+hit per agent spawn) and falls back to a hardcoded map when the table/row is
+missing, so resolution NEVER breaks agent spawning.
+"""
+
+from django.test import TestCase
+
+from teatree.core.model_tier_resolver import (
+    FALLBACK_TIER_MODELS,
+    TIERS,
+    clear_tier_model_cache,
+    resolve_tier_model,
+)
+from teatree.core.models import ModelTier
+
+
+class TestModelTierTable(TestCase):
+    def setUp(self) -> None:
+        clear_tier_model_cache()
+
+    def tearDown(self) -> None:
+        clear_tier_model_cache()
+
+    def test_seed_rows_present_for_every_tier(self) -> None:
+        # The seed migration populates one row per abstract tier.
+        for tier in TIERS:
+            assert ModelTier.objects.filter(tier=tier).exists(), tier
+
+    def test_resolve_reads_the_table(self) -> None:
+        for tier in TIERS:
+            row = ModelTier.objects.get(tier=tier)
+            assert resolve_tier_model(tier) == row.model
+
+    def test_set_model_upserts_and_clears_cache(self) -> None:
+        before = resolve_tier_model("frontier")
+        ModelTier.objects.set_model("frontier", "some-new-model-id")
+        # The table is the single source; the remap is visible after a set.
+        assert resolve_tier_model("frontier") == "some-new-model-id"
+        assert resolve_tier_model("frontier") != before
+
+    def test_tier_is_unique(self) -> None:
+        ModelTier.objects.set_model("balanced", "x")
+        ModelTier.objects.set_model("balanced", "y")
+        assert ModelTier.objects.filter(tier="balanced").count() == 1
+        assert resolve_tier_model("balanced") == "y"
+
+
+class TestResolverCache(TestCase):
+    def setUp(self) -> None:
+        clear_tier_model_cache()
+
+    def tearDown(self) -> None:
+        clear_tier_model_cache()
+
+    def test_cache_serves_repeated_reads_without_restale(self) -> None:
+        first = resolve_tier_model("frontier")
+        second = resolve_tier_model("frontier")
+        assert first == second
+
+    def test_cache_does_not_serve_a_stale_value_after_remap(self) -> None:
+        original = resolve_tier_model("fast")
+        ModelTier.objects.set_model("fast", "remapped-fast")
+        # set_model clears the cache, so the next read is the remapped value,
+        # never the cached original — the cache does not go stale incorrectly.
+        assert resolve_tier_model("fast") == "remapped-fast"
+        assert resolve_tier_model("fast") != original
+
+
+class TestFallbackNeverBreaksSpawn(TestCase):
+    def setUp(self) -> None:
+        clear_tier_model_cache()
+
+    def tearDown(self) -> None:
+        clear_tier_model_cache()
+
+    def test_missing_row_falls_back_to_hardcoded_map(self) -> None:
+        ModelTier.objects.filter(tier="frontier").delete()
+        clear_tier_model_cache()
+        # A missing row resolves to the built-in fallback — never an exception,
+        # so agent spawning can never break on a missing table row.
+        assert resolve_tier_model("frontier") == FALLBACK_TIER_MODELS["frontier"]
+
+    def test_empty_table_falls_back_for_every_tier(self) -> None:
+        ModelTier.objects.all().delete()
+        clear_tier_model_cache()
+        for tier in TIERS:
+            assert resolve_tier_model(tier) == FALLBACK_TIER_MODELS[tier]
+
+    def test_unknown_tier_falls_back_to_balanced(self) -> None:
+        # An unrecognised tier name resolves to the balanced fallback rather
+        # than raising — defensive, so a typo never breaks a spawn.
+        assert resolve_tier_model("nonexistent-tier") == FALLBACK_TIER_MODELS["balanced"]
