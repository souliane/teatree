From 70eb76302e28a56bb80313ca5765c8626cf8406f Mon Sep 17 00:00:00 2001
From: souliane <21343492+souliane@users.noreply.github.com>
Date: Thu, 25 Jun 2026 22:08:47 +0200
Subject: [PATCH 2/2] fix(e2e): make e2e_review HOLD matcher DOTALL-tolerant

The positive matcher 'review record.*--verdict hold' compiles without
re.DOTALL, so '.' cannot cross the newline in the canonical multi-line
(backslash-continuation) 'review record ... --verdict hold' command the
/t3:e2e-review skill teaches. A correct agent that records the verdict
the documented way fails the matcher; the _pass fixture only matched
because its command was hand-written single-line. The inline (?s) flag
makes '.' span newlines so both the multi-line and single-line forms
match, while the unrelated merge_safe command still does not.
---
 evals/scenarios/e2e_review.yaml | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/evals/scenarios/e2e_review.yaml b/evals/scenarios/e2e_review.yaml
index e3a2da0db4..0a2d6eb477 100644
--- a/evals/scenarios/e2e_review.yaml
+++ b/evals/scenarios/e2e_review.yaml
@@ -34,6 +34,6 @@
     command only, no narration.
   expect:
     - tool_call: Bash
-      args.command: '~ "review record.*--verdict hold"'
+      args.command: '~ "(?s)review record.*--verdict hold"'
     - no_tool_call_matching:
         Bash.command: '~ "(--verdict merge_safe|gh pr (approve|review .*--approve)|glab mr approve)"'
