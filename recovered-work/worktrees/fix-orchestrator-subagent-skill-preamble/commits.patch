+def _split_skill_args(values: list[str]) -> list[str]:
+    """Flatten repeated and comma-separated ``--skills`` values, order-preserving."""
+    names: list[str] = []
+    for value in values:
+        names.extend(part.strip() for part in value.split(",") if part.strip())
+    return names
+
+
+def _skills_dir_from_skill_path(skill_path: str, project_path: Path | None) -> Path | None:
+    """Resolve the directory holding an overlay's skill subdirectories.
+
+    An overlay's ``get_skill_metadata()["skill_path"]`` is the primary skill's
+    ``SKILL.md`` path (``skills/<skill>/SKILL.md``, the generator convention) or
+    an absolute skills directory (the dogfood overlay). Both shapes reduce to
+    the directory that *contains* the per-skill subdirectories, so an arbitrary
+    overlay skill name resolves under it. A blank path falls back to
+    ``<project>/skills``.
+    """
+    if not skill_path:
+        candidate = project_path / "skills" if project_path is not None else None
+        return candidate if candidate is not None and candidate.is_dir() else None
+    p = Path(skill_path)
+    if not p.is_absolute() and project_path is not None:
+        p = project_path / p
+    if p.name == "SKILL.md":
+        return p.parent.parent
+    return p if p.is_dir() else p.parent
+
+
+def _overlay_skill_path(overlay_name: str) -> str:
+    """Best-effort ``skill_path`` from the named overlay's metadata, or ``""``."""
+    try:
+        from teatree.core.overlay_loader import get_overlay  # noqa: PLC0415
+
+        metadata = get_overlay(overlay_name or None).metadata.get_skill_metadata()
+    except Exception:
+        logger.debug("skill-preamble: overlay skill metadata unavailable", exc_info=True)
+        return ""
+    return str(metadata.get("skill_path", "")).strip()
+
+
+def _overlay_skills_dir(overlay_name: str, project_path: Path | None) -> Path | None:
+    """The active overlay's skills directory: its own ``skills/`` or metadata-derived."""
+    if project_path is not None and (project_path / "skills").is_dir():
+        return project_path / "skills"
+    return _skills_dir_from_skill_path(_overlay_skill_path(overlay_name), project_path)
+
