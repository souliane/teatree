@@ -0,0 +1,27 @@
+import pytest
+from django.test import TestCase
+
+from teatree.core.models import Session, Ticket
+from teatree.core.session import SessionNotFound, get_active_session
+
+
+class TestGetActiveSession(TestCase):
+    def test_raises_session_not_found_when_no_active_session_exists(self) -> None:
+        with pytest.raises(SessionNotFound):
+            get_active_session("agent-with-no-session")
+
+    def test_returns_active_session_when_one_exists(self) -> None:
+        ticket = Ticket.objects.create()
+        session = Session.objects.create(ticket=ticket, agent_id="agent-1")
+
+        result = get_active_session("agent-1")
+
+        assert result.pk == session.pk
+
+    def test_ignores_ended_sessions(self) -> None:
+        ticket = Ticket.objects.create()
+        session = Session.objects.create(ticket=ticket, agent_id="agent-2")
+        session.begin_manual_handoff()
+
+        with pytest.raises(SessionNotFound):
+            get_active_session("agent-2")
