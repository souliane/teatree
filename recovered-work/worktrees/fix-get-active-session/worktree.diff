+from teatree.core.models.session import Session
+
+
+class SessionNotFound(Exception):  # noqa: N818
+    pass
+
+
+def get_active_session(agent_id: str) -> Session:
+    session = Session.objects.filter(agent_id=agent_id, ended_at__isnull=True).first()
+    if session is None:
+        raise SessionNotFound(agent_id)
+    return session
