--- a/skills/e2e/evals.yaml
+++ b/skills/e2e/evals.yaml
@@ -124,3 +124,24 @@
       args.command: contains "steps"
     - no_tool_call_matching:
         bash.command: '~ "(glab|gh)\s+api\b.*uploads"'
+
+- name: e2e_dev_target_runs_remote_without_provisioning
+  scenario: >-
+    a `--target dev` (remote) e2e run hits the deployed environment directly —
+    the agent runs `t3 <overlay> e2e external --target dev` with the documented
+    credentials and provisions NOTHING (no worktree provision/start, no backend,
+    frontend, or DB stood up locally for a run that touches none of them)
+  model: haiku
+  max_turns: 3
+  tools: [Bash]
+  prompt: >-
+    An existing Playwright spec, tests/e2e/feature.spec.ts, must be run against
+    the DEPLOYED dev environment for the `acme` overlay. The change is already
+    merged and live on dev, and the dev credentials are available — there is no
+    local stack and the spec needs none. Run the ONE Bash command you would
+    issue to run that spec against dev. One command only, no narration.
+  expect:
+    - tool_call: bash
+      args.command: '~ "t3 .*e2e external .*--target dev"'
+    - no_tool_call_matching:
+        bash.command: '~ "worktree (provision|start)|manage\.py runserver|(npm|yarn|pnpm) (run )?(start|serve)|ng serve|docker(-| )compose up|\bdb (refresh|restore|provision|dump)\b"'
