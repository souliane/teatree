+# ── t3 review post-comment: positional NOTE body + destination tier ──────────
+#
+# The colleague-review note path (``t3 review post-comment <repo> <mr> <note>``)
+# carries its body as the positional NOTE and posts to a GitLab project path.
+# Two over-blocks fixed here: the positional NOTE's ``$(cat <path>)`` / ``$VAR``
+# indirection now resolves like a ``--body`` flag value (#1780), and the NOTE's
+# destination ``<repo>`` now classifies PUBLIC vs INTERNAL the same way a
+# ``gh``/``glab`` ``--repo`` target does, so an overlay-infra brand word native
+# to a private internal GitLab namespace stops false-positiving (#1937).
+
+_T3_REVIEW_BRAND_CONFIG = '[teatree]\nbanned_terms = ["acmeoverlay"]\ninternal_publish_namespaces = ["internal-eng"]\n'
+
+
+def test_t3_review_positional_note_from_in_command_heredoc_is_allowed(
+    tmp_path: Path, monkeypatch: pytest.MonkeyPatch, capsys: pytest.CaptureFixture[str]
+) -> None:
+    # MUST-NOT-BLOCK (#1780): the positional NOTE is ``$(cat <path>)`` where the
+    # path is written by a heredoc EARLIER in the SAME command. At PreToolUse the
+    # file is not on disk yet, so the NOTE resolves from the in-command heredoc
+    # body and the clean note scans clean toward the PUBLIC repo -> allowed.
+    home = Path(os.environ["HOME"])
+    _write_home_config(home, _T3_REVIEW_BRAND_CONFIG, monkeypatch, tmp_path)
+    monkeypatch.setattr(_repo_visibility, "_resolve_probe_tool", lambda _tool: None)
+
+    body_path = tmp_path / "note-body.txt"
+    command = (
+        f"cat > {body_path} <<'EOF'\n"
+        "a perfectly clean colleague review note\n"
+        "EOF\n"
+        f't3 teatree review post-comment public-org/some-svc 7 "$(cat {body_path})"'
+    )
+    data = {"tool_name": "Bash", "tool_input": {"command": command}, "cwd": str(_public_clone(tmp_path))}
+    blocked = handle_banned_terms_pretool(data)
+    captured = capsys.readouterr()
+
+    assert blocked is False
+    assert captured.out == ""  # no deny JSON
+
