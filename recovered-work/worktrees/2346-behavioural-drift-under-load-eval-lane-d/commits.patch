-    is unchanged, so a clean-room run is byte-identical.
+    lane this is replaced by the bounded multi-skill bundle (the scenario's graded
+    skill + ``rules`` + as many others as fit the budget) framed with
+    :data:`SKILL_BUNDLE_FRAMING` and the same live-env framing; every other lane is
+    unchanged, so a clean-room run is byte-identical.
     """
     if spec.lane != UNDER_LOAD_LANE:
         return clean_room_prompt
-    return SKILL_BUNDLE_FRAMING + load_skill_bundle(skills_dir=skills_dir) + LIVE_ENV_FRAMING
+    bundle = load_skill_bundle(skills_dir=skills_dir, priority_skills=bundle_priority_skills(spec))
+    return SKILL_BUNDLE_FRAMING + bundle + LIVE_ENV_FRAMING
 
 
 def build_user_prompt(spec: EvalSpec) -> str:
