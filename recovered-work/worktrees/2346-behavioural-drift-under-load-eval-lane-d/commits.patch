 #: so the model can tell where one skill's rules end and the next begin.
 _SKILL_BUNDLE_SEPARATOR = "\n\n"
 
+#: The cross-cutting invariant home — always in the bundle, since most under_load
+#: rules live here and the lane is the home of the shared-rule overload condition.
+_RULES_SKILL = "rules"
 
-def load_skill_bundle(*, skills_dir: Path = SKILLS_DIR) -> str:
-    """Concatenate every shipped ``skills/<name>/SKILL.md`` into one bundle.
+#: Character budget for the assembled bundle. The *whole* skills tree is ~636 KB
+#: (~182 k tokens) — alone it overflows the cheap drift-prone model's context
+#: window (haiku ~200 k), so the lane was measuring "Prompt is too long" /
+#: budget-cap thrash, NOT instruction-following: even a CORRECT first action was
+#: tainted RED because the next tool-result turn pushed the context over the cap.
+#: This budget keeps the bundle a genuine MULTI-skill overload (still ~5-6 large
+#: skills, far past one clean-room skill) while leaving the model room for the
+#: ~8-20 k-token polluted preamble, the tool schemas, and a couple of tool-result
+#: turns — so a rule that survives real context pressure grades GREEN and a real
+#: drift grades RED. ~320 KB ≈ ~90 k tokens, ~110 k tokens of headroom on haiku.
+BUNDLE_BUDGET_CHARS = 320_000
 
-    Each skill's body is prefixed with a ``## skill: <name>`` header so the
-    bundle reads as the model's complete, multi-skill operating ruleset (the
-    drift-inducing overload condition). Skills are sorted for a deterministic,
-    reproducible bundle. A skill directory with no ``SKILL.md`` is skipped.
+
+def _skill_name(skill_md: Path) -> str:
+    return skill_md.parent.name
+
+
+def _bundle_section(skill_md: Path) -> str:
+    body = skill_md.read_text(encoding="utf-8").strip()
+    return f"## skill: {_skill_name(skill_md)}\n\n{body}" if body else ""
+
+
+def load_skill_bundle(
+    *,
+    skills_dir: Path = SKILLS_DIR,
+    priority_skills: tuple[str, ...] = (),
+    budget_chars: int = BUNDLE_BUDGET_CHARS,
+) -> str:
+    """Assemble a bounded, multi-skill ``skills/<name>/SKILL.md`` overload bundle.
+
+    Each skill's body is prefixed with a ``## skill: <name>`` header so the bundle
+    reads as the model's multi-skill operating ruleset (the drift-inducing overload
+    condition). ``priority_skills`` are placed FIRST and never dropped — the
+    scenario's own graded skill (the rule under test) and the cross-cutting
+    ``rules`` home MUST be present, otherwise the rule the scenario measures is not
+    even in the bundle (a worse vacuity than overload). The remaining skills, in
+    sorted order, fill up to ``budget_chars`` and the rest are dropped, so the
+    bundle stays large enough to be real overload yet small enough that the cheap
+    drift-prone model can still act within its context window (see
+    :data:`BUNDLE_BUDGET_CHARS`). A skill directory with no ``SKILL.md`` is skipped.
     """
+    by_name = {_skill_name(p): p for p in sorted(skills_dir.glob("*/SKILL.md"))}
+    ordered: list[str] = []
+    for name in priority_skills:
+        if name in by_name and name not in ordered:
+            ordered.append(name)
+    for name in sorted(by_name):
+        if name not in ordered:
+            ordered.append(name)
+
     sections: list[str] = []
-    for skill_md in sorted(skills_dir.glob("*/SKILL.md")):
-        body = skill_md.read_text(encoding="utf-8").strip()
-        if not body:
+    used = 0
+    forced = set(priority_skills)
+    for name in ordered:
+        section = _bundle_section(by_name[name])
+        if not section:
             continue
-        sections.append(f"## skill: {skill_md.parent.name}\n\n{body}")
+        addition = len(section) + (len(_SKILL_BUNDLE_SEPARATOR) if sections else 0)
+        if name not in forced and used + addition > budget_chars:
+            continue
+        sections.append(section)
+        used += addition
     return _SKILL_BUNDLE_SEPARATOR.join(sections)
 
 
+def bundle_priority_skills(spec: EvalSpec) -> tuple[str, ...]:
+    """The skills that MUST be in *spec*'s bundle: its graded skill, then ``rules``.
+
+    ``spec.agent_path`` is ``skills/<name>/SKILL.md`` — the rule under test lives in
+    ``<name>``, so it is never budget-dropped; ``rules`` is the cross-cutting home
+    most under_load invariants are restated from. Order puts the graded skill first.
+    """
+    graded = Path(spec.agent_path).parent.name
+    priority = [graded]
+    if _RULES_SKILL not in priority:
+        priority.append(_RULES_SKILL)
+    return tuple(priority)
+
+
