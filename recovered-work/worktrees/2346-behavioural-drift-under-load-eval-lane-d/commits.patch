+class TestRealBundleIsOperable:
+    """The shipped bundle must fit the cheap model's window, not overflow it.
+
+    The whole skills tree (~636 KB / ~182 k tokens) alone overflows haiku's
+    ~200 k-token window, so the lane measured 'Prompt is too long' / budget-cap
+    thrash instead of instruction-following (#2346). The bounded bundle keeps the
+    real under_load system prompt well under the window with headroom for the
+    preamble + tool turns.
+    """
+
+    def test_real_under_load_system_prompt_stays_within_budget(self) -> None:
+        under_load = [s for s in discover_specs() if s.lane == UNDER_LOAD_LANE]
+        assert under_load, "expected at least one under_load scenario to exist"
+        for spec in under_load:
+            sysp = build_system_prompt(spec, clean_room_prompt="X")
+            user = build_user_prompt(spec)
+            # The graded skill's rule must be present (never budget-dropped) ...
+            graded = Path(spec.agent_path).parent.name
+            assert f"## skill: {graded}" in sysp, f"{spec.name}: graded skill {graded} missing from bundle"
+            # ... and the whole prompt must leave the model room to act: cap the
+            # combined system+user size so a tool-result turn cannot overflow the
+            # window. The budget + the largest preamble must stay comfortably below
+            # the ~200 k-token (~700 k-char) haiku window.
+            assert len(sysp) + len(user) < BUNDLE_BUDGET_CHARS + 60_000, (
+                f"{spec.name}: system+user prompt {len(sysp) + len(user):,}c exceeds the operable budget"
+            )
+
+
