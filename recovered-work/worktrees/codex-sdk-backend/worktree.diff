diff --git src/teatree/eval/codex_runner.py src/teatree/eval/codex_runner.py
new file mode 100644
index 0000000000..9d54a1bcc6
--- /dev/null
+++ src/teatree/eval/codex_runner.py
@@ -0,0 +1,234 @@
+"""OpenAI Codex SDK runner for behavioral evals."""
+
+import dataclasses
+import json
+from pathlib import Path
+from typing import Any
+
+from openai_codex import ApprovalMode, Codex, CodexConfig, Sandbox
+from openai_codex.generated.v2_all import (
+    AgentMessageThreadItem,
+    CollabAgentToolCallThreadItem,
+    CommandExecutionThreadItem,
+    DynamicToolCallThreadItem,
+    McpToolCallThreadItem,
+    MessagePhase,
+    ReasoningEffort,
+    ThreadItem,
+    ThreadTokenUsage,
+    TurnStatus,
+    WebSearchThreadItem,
+)
+
+from teatree.eval.local_sdk_backend import LocalHarnessSDKBackend
+from teatree.eval.model_variant import parse_model_variant
+from teatree.eval.models import EvalRun, EvalSpec, TokenUsage
+from teatree.eval.prompt_framing import LIVE_ENV_FRAMING
+from teatree.eval.sdk_runner import load_agent_definition
+from teatree.eval.transcript import extract_text_blocks, extract_tool_calls, parse_stream_json
+from teatree.eval.under_load import build_system_prompt, build_user_prompt
+
+_CODEX_EFFORTS: dict[str, ReasoningEffort] = {
+    "low": ReasoningEffort.low,
+    "medium": ReasoningEffort.medium,
+    "high": ReasoningEffort.high,
+    "xhigh": ReasoningEffort.xhigh,
+    "max": ReasoningEffort.xhigh,
+}
+
+
+class CodexSdkRunner(LocalHarnessSDKBackend):
+    """Run an :class:`EvalSpec` through the local ``openai-codex`` SDK."""
+
+    def __init__(
+        self,
+        *,
+        workspace: Path | None = None,
+        max_turns_override: int | None = None,
+        require_executed: bool = False,
+        max_budget_usd: float = 0.0,
+        effort: str | None = None,
+    ) -> None:
+        self._workspace = workspace or Path.cwd()
+        self._max_turns_override = max_turns_override
+        self._require_executed = require_executed
+        self._max_budget_usd = max_budget_usd
+        self._effort = effort
+
+    def run(self, spec: EvalSpec) -> EvalRun:
+        clean_room_prompt = load_agent_definition(spec.agent_path, spec.agent_sections) + LIVE_ENV_FRAMING
+        system_prompt = build_system_prompt(spec, clean_room_prompt=clean_room_prompt)
+        variant = parse_model_variant(spec.model)
+        effort = _codex_effort(variant.effort or self._effort)
+        config = CodexConfig(
+            cwd=str(self._workspace),
+            client_name="teatree_eval_codex",
+            client_title="TeaTree Eval Codex",
+        )
+        try:
+            with Codex(config) as codex:
+                thread = codex.thread_start(
+                    approval_mode=ApprovalMode.auto_review,
+                    cwd=str(self._workspace),
+                    developer_instructions=system_prompt,
+                    ephemeral=True,
+                    model=variant.model,
+                    sandbox=Sandbox.full_access,
+                )
+                result = thread.run(
+                    build_user_prompt(spec),
+                    approval_mode=ApprovalMode.auto_review,
+                    cwd=str(self._workspace),
+                    effort=effort,
+                    model=variant.model,
+                    sandbox=Sandbox.full_access,
+                )
+        except Exception as exc:
+            if self._require_executed:
+                raise
+            return _terminal_run(spec, terminal_reason=f"skipped: codex sdk unavailable: {exc}", is_error=False)
+        return _eval_run_from_codex_result(spec, result)
+
+
+def _codex_effort(effort: str | None) -> ReasoningEffort | None:
+    if effort is None:
+        return None
+    return _CODEX_EFFORTS.get(effort)
+
+
+def _eval_run_from_codex_result(spec: EvalSpec, result: Any) -> EvalRun:
+    raw_stdout = _synthesize_stream_json(result)
+    events = parse_stream_json(raw_stdout)
+    terminal_reason, is_error = _terminal_state(result)
+    return EvalRun(
+        spec_name=spec.name,
+        tool_calls=tuple(extract_tool_calls(events)),
+        text_blocks=tuple(extract_text_blocks(events)),
+        terminal_reason=terminal_reason,
+        is_error=is_error,
+        raw_stdout=raw_stdout,
+        raw_stderr="",
+        usage=_usage_from_result(result),
+    )
+
+
+def _terminal_state(result: Any) -> tuple[str, bool]:
+    status = getattr(result, "status", None)
+    if status == TurnStatus.completed:
+        return "success", False
+    if status == TurnStatus.interrupted:
+        return "interrupted", True
+    if status == TurnStatus.failed:
+        error = getattr(result, "error", None)
+        message = getattr(error, "message", None)
+        return message if isinstance(message, str) and message else "failed", True
+    return "aborted", True
+
+
+def _usage_from_result(result: Any) -> TokenUsage:
+    usage = getattr(result, "usage", None)
+    if not isinstance(usage, ThreadTokenUsage):
+        return TokenUsage()
+    total = usage.total
+    return TokenUsage(
+        input=total.input_tokens,
+        cache_read=total.cached_input_tokens,
+        output=total.output_tokens + total.reasoning_output_tokens,
+    )
+
+
+def _synthesize_stream_json(result: Any) -> str:
+    lines: list[str] = []
+    for item in getattr(result, "items", []):
+        event = _item_to_event(item)
+        if event is not None:
+            lines.append(_json_line(event))
+    lines.append(
+        _json_line(
+            {
+                "type": "result",
+                "subtype": _terminal_state(result)[0],
+                "is_error": _terminal_state(result)[1],
+                "usage": _usage_event(getattr(result, "usage", None)),
+                "codex_items": [_model_dump(item) for item in getattr(result, "items", [])],
+            }
+        )
+    )
+    return "\n".join(lines) + "\n"
+
+
+def _item_to_event(item: Any) -> dict[str, Any] | None:
+    unwrapped = _unwrap_item(item)
+    if isinstance(unwrapped, AgentMessageThreadItem):
+        return _agent_message_event(unwrapped)
+    block = _tool_block(unwrapped)
+    if block is None:
+        return None
+    return {"type": "assistant", "message": {"content": [block]}}
+
+
+def _agent_message_event(item: AgentMessageThreadItem) -> dict[str, Any] | None:
+    if item.phase not in (None, MessagePhase.final_answer):
+        return None
+    return {"type": "assistant", "message": {"content": [{"type": "text", "text": item.text}]}}
+
+
+def _tool_block(item: Any) -> dict[str, Any] | None:
+    if isinstance(item, CommandExecutionThreadItem):
+        return {"type": "tool_use", "name": "Bash", "input": {"command": item.command}}
+    if isinstance(item, McpToolCallThreadItem):
+        return {"type": "tool_use", "name": f"mcp__{item.server}__{item.tool}", "input": _dict_or_empty(item.arguments)}
+    if isinstance(item, DynamicToolCallThreadItem):
+        name = f"{item.namespace}__{item.tool}" if item.namespace else item.tool
+        return {"type": "tool_use", "name": name, "input": _dict_or_empty(item.arguments)}
+    if isinstance(item, CollabAgentToolCallThreadItem):
+        return {"type": "tool_use", "name": "Agent", "input": {"prompt": item.prompt or "", "model": item.model or ""}}
+    if isinstance(item, WebSearchThreadItem):
+        return {"type": "tool_use", "name": "WebSearch", "input": {"query": item.query}}
+    return None
+
+
+def _dict_or_empty(value: Any) -> dict[str, Any]:
+    return dict(value) if isinstance(value, dict) else {}
+
+
+def _usage_event(usage: Any) -> dict[str, int] | None:
+    if not isinstance(usage, ThreadTokenUsage):
+        return None
+    total = usage.total
+    return {
+        "input_tokens": total.input_tokens,
+        "cache_creation_input_tokens": 0,
+        "cache_read_input_tokens": total.cached_input_tokens,
+        "output_tokens": total.output_tokens + total.reasoning_output_tokens,
+    }
+
+
+def _unwrap_item(item: Any) -> Any:
+    if isinstance(item, ThreadItem):
+        return item.root
+    return getattr(item, "root", item)
+
+
+def _model_dump(value: Any) -> Any:
+    if hasattr(value, "model_dump"):
+        return value.model_dump(by_alias=True, exclude_none=True, mode="json")
+    if dataclasses.is_dataclass(value):
+        return dataclasses.asdict(value)
+    return value
+
+
+def _json_line(value: dict[str, Any]) -> str:
+    return json.dumps(value, separators=(",", ":"))
+
+
+def _terminal_run(spec: EvalSpec, *, terminal_reason: str, is_error: bool) -> EvalRun:
+    return EvalRun(
+        spec_name=spec.name,
+        tool_calls=(),
+        text_blocks=(),
+        terminal_reason=terminal_reason,
+        is_error=is_error,
+        raw_stdout="",
+        raw_stderr="",
+    )

