+"""Shared contract for local SDK-backed eval runners."""
+
+from abc import ABC, abstractmethod
+
+from teatree.eval.models import EvalRun, EvalSpec
+
+
+class LocalHarnessSDKBackend(ABC):
+    """Local model runner that executes one eval scenario and returns grader input."""
+
+    @abstractmethod
+    def run(self, spec: EvalSpec) -> EvalRun: ...

