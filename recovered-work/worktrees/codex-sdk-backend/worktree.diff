+++ tests/teatree_eval/test_codex_runner.py
@@ -0,0 +1,208 @@
+"""OpenAI Codex SDK eval runner.
+
+The SDK boundary is mocked here; these tests pin how Codex thread items are
+rendered into the existing TeaTree stream-json extractor shape.
+"""
+
+from pathlib import Path
+from typing import Any
+from unittest.mock import patch
+
+import pytest
+from openai_codex import TurnResult
+from openai_codex.generated.v2_all import (
+    AbsolutePathBuf,
+    AgentMessageThreadItem,
+    CommandExecutionStatus,
+    CommandExecutionThreadItem,
+    DynamicToolCallStatus,
+    DynamicToolCallThreadItem,
+    McpToolCallStatus,
+    McpToolCallThreadItem,
+    MessagePhase,
+    ThreadItem,
+    ThreadTokenUsage,
+    TokenUsageBreakdown,
+    TurnStatus,
+)
+
+from teatree.eval.codex_runner import CodexSdkRunner
+from teatree.eval.models import EvalSpec, Matcher, TokenUsage
+
+
+def _spec(tmp_path: Path, *, model: str = "gpt-5.5@high") -> EvalSpec:
+    agent = tmp_path / "agent.md"
+    agent.write_text("# fake skill\n\nbody\n", encoding="utf-8")
+    return EvalSpec(
+        name="worktree_first",
+        scenario="agent must create a worktree first",
+        agent_path=str(agent),
+        prompt="Fix README.md typo.",
+        matchers=(
+            Matcher(kind="positive", tool="Bash", arg_path="command", operator="contains", value="git worktree add"),
+        ),
+        source_path=tmp_path / "spec.yaml",
+        model=model,
+        max_turns=3,
+        tools=("Bash",),
+    )
+
+
+def _usage() -> ThreadTokenUsage:
+    return ThreadTokenUsage(
+        last=TokenUsageBreakdown(
+            inputTokens=10,
+            cachedInputTokens=2,
+            outputTokens=3,
+            reasoningOutputTokens=4,
+            totalTokens=19,
+        ),
+        total=TokenUsageBreakdown(
+            inputTokens=100,
+            cachedInputTokens=20,
+            outputTokens=30,
+            reasoningOutputTokens=40,
+            totalTokens=190,
+        ),
+    )
+
+
+def _completed_result(items: list[ThreadItem]) -> TurnResult:
+    return TurnResult(
+        id="turn-1",
+        status=TurnStatus.completed,
+        error=None,
+        started_at=None,
+        completed_at=None,
+        duration_ms=1,
+        final_response="done",
+        items=items,
+        usage=_usage(),
+    )
+
+
+class _FakeCodex:
+    captured: dict[str, Any]
+    result: TurnResult
+
+    def __init__(self, config: Any = None) -> None:
+        self.captured = {"config": config}
+        type(self).captured = self.captured
+
+    def __enter__(self) -> "_FakeCodex":
+        return self
+
+    def __exit__(self, _exc_type: object, _exc: object, _tb: object) -> None:
+        return None
+
+    def thread_start(self, **kwargs: Any) -> "_FakeThread":
+        self.captured["thread_start"] = kwargs
+        return _FakeThread(self)
+
+
+class _FakeThread:
+    def __init__(self, codex: _FakeCodex) -> None:
+        self._codex = codex
+
+    def run(self, input: str, **kwargs: Any) -> TurnResult:
+        self._codex.captured["run_input"] = input
+        self._codex.captured["run_kwargs"] = kwargs
+        return _FakeCodex.result
+
+
+class TestCodexSdkRunner:
+    def _run(self, spec: EvalSpec, result: TurnResult) -> tuple[Any, dict[str, Any]]:
+        _FakeCodex.result = result
+        with patch("teatree.eval.codex_runner.Codex", _FakeCodex):
+            run = CodexSdkRunner(workspace=spec.source_path.parent).run(spec)
+        return run, _FakeCodex.captured
+
+    def test_captures_codex_messages_commands_tools_terminal_and_usage(self, tmp_path: Path) -> None:
+        spec = _spec(tmp_path)
+        items = [
+            ThreadItem(
+                AgentMessageThreadItem(
+                    id="msg-1",
+                    phase=MessagePhase.final_answer,
+                    text="Creating a worktree first.",
+                    type="agentMessage",
+                )
+            ),
+            ThreadItem(
+                CommandExecutionThreadItem(
+                    id="cmd-1",
+                    command="git worktree add ../wt HEAD",
+                    commandActions=[],
+                    cwd=AbsolutePathBuf(str(tmp_path)),
+                    status=CommandExecutionStatus.completed,
+                    type="commandExecution",
