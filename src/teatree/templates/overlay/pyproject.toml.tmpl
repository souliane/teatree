[build-system]
build-backend = "uv_build"
requires = ["uv_build>=0.7,<0.11"]

[project]
name = "{{project_name}}"
version = "0.0.1"
description = "{{description}}"
requires-python = ">=3.13"
dependencies = [
  "django>=5.2,<6.1",
  "django-tasks-db>=0.12",
  "django-htmx>=1.27",
  "django-rich>=2.2.0",
  "django-tasks>=0.9",
  "teatree",
]
scripts = { t3 = "teatree.cli:main" }

[project.entry-points."teatree.overlays"]
{{project_name}} = "{{package_name}}.settings"

[dependency-groups]
dev = [
  "django-types>=0.23",
  "import-linter>=2.5.2",
  "prek>=0.2.12",
  "pytest>=9.0.2",
  "pytest-cov>=7",
  "pytest-django>=4.11.1",
  "ruff>=0.14.2",
  "safety>=3",
  "ty>=0.0.18",
  "typer>=0.12",
]

[tool.uv.build-backend]
module-name = ["{{overlay_app}}", "{{package_name}}"]
module-root = "src"

[tool.ruff]
target-version = "py313"
line-length = 120
fix = true
lint.select = ["ALL"]
lint.ignore = [
  "CPY001",
  "D100", "D101", "D102", "D103", "D104", "D105", "D106", "D107",
  "D203", "D213",
  "DOC201", "DOC402", "DOC501",
  "INP001",
  "ISC002",
]
lint.extend-ignore = [
  "COM812", "COM819",
  "D206", "D300",
  "E111", "E114", "E117",
  "Q000", "Q001", "Q002", "Q003", "Q004",
  "W191",
]
lint.per-file-ignores."{{overlay_app}}/overlay.py" = [
  "ARG002", "PLR6301",
]
lint.per-file-ignores."tests/**/*.py" = [
  "ANN", "ARG001", "ARG005", "FLY002",
  "PLC1901", "PLC2701", "PLR2004", "PLR6301",
  "S101", "S105", "S108", "S404", "SLF001",
]
lint.fixable = ["ALL"]
lint.flake8-implicit-str-concat.allow-multiline = false
lint.flake8-tidy-imports.banned-api."__future__.annotations" = { msg = "Use native 3.13+ syntax (X | Y)" }
lint.isort.split-on-trailing-comma = false
lint.pydocstyle.convention = "google"
lint.pylint.max-args = 5
lint.pylint.max-bool-expr = 5
lint.pylint.max-branches = 12
lint.pylint.max-locals = 15
lint.pylint.max-nested-blocks = 5
lint.pylint.max-returns = 6
lint.pylint.max-statements = 50
lint.preview = true

[tool.codespell]

[tool.pytest.ini_options]
addopts = """
--color=yes --exitfirst --failed-first
--strict-config --strict-markers --verbose --log-cli-level=INFO
--cov --cov-report=term-missing:skip-covered --cov-branch
--ds={{package_name}}.settings
"""
DJANGO_SETTINGS_MODULE = "{{package_name}}.settings"
django_find_project = false
pythonpath = [".", "src"]
testpaths = ["tests"]
filterwarnings = ["error"]
xfail_strict = true

[tool.coverage.report]
fail_under = 100
precision = 1
show_missing = true
exclude_lines = [
  "if __name__",
  "if TYPE_CHECKING",
  "pragma: no cover",
]
partial_branches = []

[tool.coverage.run]
branch = true
source = ["src/{{overlay_app}}", "src/{{package_name}}"]

[tool.importlinter]
root_packages = ["{{overlay_app}}", "{{package_name}}", "tests"]
include_external_packages = true
exclude_type_checking_imports = false

[tool.ty]
terminal = { error-on-warning = true }

[tool.ty.environment]
extra-paths = [".", "src"]
python-version = "3.13"

[tool.ty.rules]
division-by-zero = "error"
possibly-unresolved-reference = "error"
invalid-argument-type = "ignore"
invalid-method-override = "ignore"
unsupported-operator = "ignore"
unresolved-attribute = "ignore"

[tool.uv]
managed = true
package = true

[tool.uv.sources]
teatree = { git = "https://github.com/souliane/teatree.git" }
