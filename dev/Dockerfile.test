FROM ubuntu:latest
RUN apt-get update -qq && \
    apt-get install -y -qq curl direnv git jq >/dev/null 2>&1 && \
    rm -rf /var/lib/apt/lists/* && \
    useradd -m testuser
USER testuser
RUN curl -LsSf https://astral.sh/uv/install.sh | sh -s -- -q 2>/dev/null
ENV PATH="/home/testuser/.local/bin:$PATH"
WORKDIR /app
